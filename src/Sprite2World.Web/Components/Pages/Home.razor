    private async Task LoadSpriteColorPreferences()
    {
        var primary = await JS.InvokeAsync<string?>("sprite2world.getPreference", "spritePrimaryColor");
        var secondary = await JS.InvokeAsync<string?>("sprite2world.getPreference", "spriteSecondaryColor");
        if (IsHexColor(primary)) spriteColor = primary!.ToLowerInvariant();
        if (IsHexColor(secondary)) spriteSecondaryColor = secondary!.ToLowerInvariant();
        var saved = await JS.InvokeAsync<string?>("sprite2world.getPreference", "spritePalettes");
        if (string.IsNullOrWhiteSpace(saved)) return;
        try
        {
            var palettes = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, List<string>>>(saved);
            if (palettes is null) return;
            foreach (var channel in new[] { MaterialChannel.Base, MaterialChannel.Normal, MaterialChannel.Metallic, MaterialChannel.Roughness })
            {
                if (!palettes.TryGetValue(channel.ToString(), out var colors)) continue;
                spritePalettes[channel] = colors.Where(IsHexColor).Select(color => color.ToLowerInvariant()).Distinct(StringComparer.OrdinalIgnoreCase).Take(1000).ToList();
            }
        }
        catch (System.Text.Json.JsonException) { }
    }
    private Task SaveSpritePalettes() => JS.InvokeVoidAsync("sprite2world.setPreference", "spritePalettes", System.Text.Json.JsonSerializer.Serialize(spritePalettes.ToDictionary(pair => pair.Key.ToString(), pair => pair.Value))).AsTask();
