@page "/"
@implements IAsyncDisposable
@inject EditorState State
@inject UiLocalizer Localizer
@inject OpenAiCredentialState Credentials
@inject IJSRuntime JS
@inject ILogger<Home> Logger

<PageTitle>Sprite2World · @T("AI Level Designer", "KI-Level-Designer")</PageTitle>

<div class="app-shell">
    <main class="editor-grid @(assetPanelCollapsed || assetPanelFloating ? "assets-out" : "") @(layersCollapsed ? "right-out" : "")">
        <nav class="global-sidebar" aria-label="@T("Project actions", "Projektaktionen")">
            <div class="rail-brand" title="Sprite2World · @T("AI Level Designer", "KI-Level-Designer")"><img class="rail-brand-logo" src="/sprite2world-logo.png" alt="Sprite2World" /></div>
            <button class="rail-action @(!libraryStudioOpen || libraryTab == "projects" ? "primary" : "")" @onclick="OpenWorldsSection" title="@(libraryStudioOpen && libraryTab == "sprites" ? T("Return to the active world", "Zur aktiven Welt zurückkehren") : !libraryStudioOpen ? T("Choose another world", "Andere Welt auswählen") : T("Open active world", "Aktive Welt öffnen"))">◇<span>@T("Worlds", "Welten")</span></button>
            <button class="rail-action @(libraryStudioOpen && libraryTab == "sprites" ? "primary" : "")" @onclick="OpenSpritesSection" title="@T("Open sprite library", "Sprite-Bibliothek öffnen")">▦<span>@T("Sprites", "Sprites")</span></button>
            <div class="rail-spacer"></div>
            <button class="rail-action" @onclick="() => showSettings = true" title="@T("Settings", "Einstellungen")">⚙<span>@T("Settings", "Einstellungen")</span></button>
        </nav>

        @if (libraryStudioOpen)
        {
            <section class="library-studio panel" aria-label="@T("Sprite and project library", "Sprite- und Projektbibliothek")">
                <header class="studio-header">
                    <div><span class="eyebrow">@(libraryTab == "projects" ? T("WORLD LIBRARY", "WELTENBIBLIOTHEK") : T("SPRITE LIBRARY", "SPRITE-BIBLIOTHEK"))</span><h1>@(libraryTab == "projects" ? T("Worlds", "Welten") : T("Sprites", "Sprites"))</h1></div>
                    <div class="studio-header-actions"><span class="studio-save-state">@(spriteAutosaving ? T("Saving automatically…", "Wird automatisch gespeichert…") : spriteDirty ? T("Autosave pending…", "Autosave ausstehend…") : T("All changes saved", "Alle Änderungen gespeichert"))</span><button class="button" @onclick="CloseLibraryStudio">@T("Open world", "Welt öffnen")</button></div>
                </header>
                <div class="studio-layout @(libraryTab == "projects" ? "projects-mode" : "")">
                    <aside class="studio-browser">
                        <div class="studio-tabs-row">
                            <div class="studio-library-label"><span class="material-symbols-rounded">@(libraryTab == "projects" ? "public" : "collections")</span><strong>@(libraryTab == "projects" ? T("Your worlds", "Deine Welten") : T("Sprite assets", "Sprite-Assets"))</strong></div>
                            <button class="studio-add" data-click-away-trigger="library-add" aria-label="@T("Add to library", "Zur Bibliothek hinzufügen")" @onclick="() => libraryAddOpen = !libraryAddOpen">＋</button>
                            @if (libraryAddOpen)
                            {
                                <div class="studio-add-menu" data-click-away-panel="library-add">
                                    @if (libraryTab == "projects") { <button @onclick="CreateProjectFromLibrary">◇ @T("New world", "Neue Welt")</button> }
                                    else { <button @onclick="() => OpenSpriteSetup(false)">＋ @T("New sprite", "Neues Sprite")</button><button @onclick="() => OpenSpriteSetup(true)">⇧ @T("Import sprites", "Sprites importieren")</button><button @onclick="LoadStarterSprites">✦ @T("Starter sprites", "Starter-Sprites")</button> }
                                </div>
                                <button class="click-away-closer" data-click-away-close="library-add" tabindex="-1" aria-hidden="true" @onclick="() => libraryAddOpen = false"></button>
                            }
                        </div>
                        @if (libraryTab == "sprites")
                        {
                            <div class="studio-search"><span>⌕</span><input placeholder="@T("Search sprites…", "Sprites suchen…")" @bind="studioSearch" @bind:event="oninput" /></div>
                            <div class="normal-filter-row">
                                @foreach (var filter in NormalStatusFilters)
                                {
                                    <button class="@(normalStatusFilter == filter.Value ? "active" : "")" @onclick="() => normalStatusFilter = filter.Value"><span class="normal-dot @filter.Css"></span>@filter.Label</button>
                                }
                            </div>
                            <nav class="sprite-library-tree" aria-label="@T("Sprite folders", "Sprite-Ordner")">
                                <div class="sprite-tree-heading"><strong>@T("Folders", "Ordner")</strong><button aria-label="@T("Create folder", "Ordner anlegen")" title="@T("Create folder", "Ordner anlegen")" @onclick="OpenCreateFolderDialog"><span class="material-symbols-rounded">add</span></button></div>
                                <button class="sprite-tree-all @(activeLibraryTheme is null ? "active" : "")" @onclick="ShowAllSpriteFolders"><span class="material-symbols-rounded">grid_view</span><strong>@T("All sprites", "Alle Sprites")</strong><small>@StudioAssets.Count()</small></button>
                                @foreach (var themeGroup in LibraryFolders.GroupBy(folder => folder.Theme).OrderBy(group => group.Key, StringComparer.OrdinalIgnoreCase))
                                {
                                    var themeKey = themeGroup.Key;
                                    var themeAssetCount = StudioAssets.Count(asset => string.Equals(AssetThemeKey(asset), themeKey, StringComparison.OrdinalIgnoreCase));
                                    <div class="sprite-tree-theme">
                                        <div class="sprite-tree-theme-row @(activeLibraryTheme == themeKey && activeLibrarySubfolder is null ? "active" : "") @(dragOverLibraryFolder == $"theme:{themeKey}" ? "drag-target" : "")" @ondragenter="() => EnterThemeDropTarget(themeKey)" @ondragover:preventDefault="true" @ondrop="() => DropSpriteOnTheme(themeKey)">
                                            <button class="tree-toggle" aria-label="@T("Toggle folder", "Ordner aufklappen") @FolderDisplayName(themeKey)" @onclick="() => ToggleLibraryTheme(themeKey)"><span class="material-symbols-rounded">@(expandedLibraryThemes.Contains(themeKey) ? "expand_more" : "chevron_right")</span></button>
                                            <button class="tree-label" @onclick="() => SelectLibraryFolder(themeKey, null)"><span class="material-symbols-rounded">@(expandedLibraryThemes.Contains(themeKey) ? "folder_open" : "folder")</span><strong>@FolderDisplayName(themeKey)</strong><small>@themeAssetCount</small></button>
                                        </div>
                                        @if (expandedLibraryThemes.Contains(themeKey))
                                        {
                                            <div class="sprite-tree-children">
                                                @foreach (var folder in themeGroup.OrderBy(folder => folder.Subfolder, StringComparer.OrdinalIgnoreCase))
                                                {
                                                    var folderKey = folder.Subfolder;
                                                    var folderAssetCount = StudioAssets.Count(asset => string.Equals(AssetThemeKey(asset), themeKey, StringComparison.OrdinalIgnoreCase) && string.Equals(AssetSubfolder(asset), folderKey, StringComparison.OrdinalIgnoreCase));
                                                    <button class="@(activeLibraryTheme == themeKey && activeLibrarySubfolder == folderKey ? "active" : "") @(dragOverLibraryFolder == $"folder:{themeKey}/{folderKey}" ? "drag-target" : "")" @onclick="() => SelectLibraryFolder(themeKey, folderKey)" @ondragenter="() => EnterFolderDropTarget(themeKey, folderKey)" @ondragover:preventDefault="true" @ondrop="() => DropSpriteIntoFolder(themeKey, folderKey)"><span class="material-symbols-rounded">folder</span><strong>@folderKey</strong><small>@folderAssetCount</small></button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </nav>
                            <div class="studio-library-results">
                                <div class="studio-results-heading"><div><span class="material-symbols-rounded">folder_open</span><strong>@ActiveLibraryFolderLabel</strong></div><small>@StudioLibraryAssets.Count() @T("items", "Elemente")</small></div>
                                <div class="studio-sprite-grid">
                                @foreach (var asset in StudioLibraryAssets)
                                {
                                    <article class="studio-sprite-card @(StudioAsset?.Id == asset.Id ? "selected" : "") @(activeAssetMenuId == asset.Id ? "menu-open" : "") @(draggingLibraryAssetId == asset.Id ? "dragging" : "")" @key="asset.Id">
                                        <button class="studio-sprite-open" draggable="true" title="@T("Drag into a folder or click to edit", "In einen Ordner ziehen oder zum Bearbeiten klicken")" @ondragstart="() => BeginSpriteDrag(asset.Id)" @ondragend="EndSpriteDrag" @onclick="() => OpenStudioAsset(asset)"><span class="studio-sprite-image"><img src="@asset.Url" alt="@asset.FileName" draggable="false" /></span><strong>@asset.FileName</strong><small>@SpriteTileSizeLabel(asset) · @RoleLabel(asset.Role)</small><em class="normal-status @NormalStatusCss(asset)"><span></span>@NormalStatusLabel(asset)</em></button>
                                        <button class="sprite-card-more" data-click-away-trigger="asset-actions" aria-label="@T("Actions for", "Aktionen für") @asset.FileName" @onclick="() => ToggleAssetMenu(asset.Id)" @onclick:stopPropagation="true"><span class="material-symbols-rounded">more_horiz</span></button>
                                        @if (activeAssetMenuId == asset.Id)
                                        {
                                            <div class="sprite-card-menu" data-click-away-panel="asset-actions" role="menu">
                                                <button role="menuitem" @onclick='() => OpenAssetManager(asset, "rename")'><span class="material-symbols-rounded">edit</span>@T("Rename", "Umbenennen")</button>
                                                <button role="menuitem" @onclick='() => OpenAssetManager(asset, "move")'><span class="material-symbols-rounded">drive_file_move</span>@T("Move to folder", "In Ordner verschieben")</button>
                                                <button class="danger" role="menuitem" @onclick="() => RemoveStudioAsset(asset)"><span class="material-symbols-rounded">delete</span>@T("Delete", "Löschen")</button>
                                            </div>
                                            <button class="click-away-closer" data-click-away-close="asset-actions" tabindex="-1" aria-hidden="true" @onclick="CloseAssetMenu"></button>
                                        }
                                    </article>
                                }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="studio-project-list">
                                @if (projectList.Count == 0) { <p class="empty-copy">@T("No saved worlds yet.", "Noch keine gespeicherten Welten.")</p> }
                                @foreach (var project in projectList)
                                {
                                    <article class="studio-project-card @(State.HasOpenProject && project.Id == State.ProjectId ? "current" : "") @(selectedLibraryProjectId == project.Id ? "selected" : "")">
                                        <button class="project-card-select" title="@T("Click once for a preview and again to open", "Einmal für die Vorschau und erneut zum Öffnen klicken")" @onclick="() => SelectProjectFromLibrary(project)">
                                            <span class="project-preview"><img src="@ProjectPreviewUrl(project)" alt="@T("Preview", "Vorschau") @LocalizedProjectName(project.Name)" /><span>@(selectedLibraryProjectId == project.Id ? T("PREVIEW", "VORSCHAU") : State.HasOpenProject && project.Id == State.ProjectId ? T("CURRENT", "AKTUELL") : T("SELECT", "AUSWÄHLEN"))</span></span>
                                            <span class="project-card-copy"><strong>@LocalizedProjectName(project.Name)</strong><small>@LocalizedDate(project.UpdatedAt)</small></span>
                                        </button>
                                        <button class="project-card-delete" aria-label="@T("Delete project", "Projekt löschen") @LocalizedProjectName(project.Name)" @onclick="() => DeleteProject(project)">×</button>
                                    </article>
                                }
                            </div>
                        }
                    </aside>

                    @if (libraryTab == "sprites")
                    {
                        <main class="sprite-editor-workspace">
                            <div class="sprite-editor-toolbar" role="toolbar" aria-label="@T("Sprite tools", "Sprite-Werkzeuge")">
                                @foreach (var tool in SpriteTools)
                                {
                                    <button class="sprite-icon-button @(spriteTool == tool.Id ? "active" : "")" aria-label="@tool.Label" aria-keyshortcuts="@tool.Shortcut" title="@SpriteToolTitle(tool.Id, tool.Label, tool.Shortcut)" @onclick="() => SetSpriteTool(tool.Id)"><span class="material-symbols-rounded">@tool.Icon</span></button>
                                }
                                <i></i><button class="sprite-icon-button" aria-label="@T("Undo", "Rückgängig")" title="@T("Undo", "Rückgängig") · Ctrl+Z" @onclick="UndoSprite"><span class="material-symbols-rounded">undo</span></button><button class="sprite-icon-button" aria-label="@T("Redo", "Wiederholen")" title="@T("Redo", "Wiederholen") · Ctrl+Y" @onclick="RedoSprite"><span class="material-symbols-rounded">redo</span></button><i></i>
                                <button class="sprite-icon-button ai-sprite-button" aria-label="@T("Draw sprite with AI", "Sprite mit KI zeichnen")" title="@SpriteAiButtonTitle" @onclick="OpenAiSpriteDialog" disabled="@(!Credentials.IsReady || StudioAsset is null || State.IsBusy)"><span class="material-symbols-rounded">auto_awesome</span><small>AI</small></button>
                                <label class="toolbar-zoom" aria-label="@T("Zoom", "Zoom")"><select value="@SpriteZoomPercent" @onchange="ChangeSpriteZoom"><option value="25">25%</option><option value="50">50%</option><option value="100">100%</option><option value="200">200%</option><option value="400">400%</option><option value="800">800%</option></select></label>
                                <div class="grid-scale-control">
                                    <button class="sprite-icon-button @(spriteGrid ? "active" : "")" aria-label="@T("Grid", "Raster")" title="@T("Toggle grid", "Raster ein- oder ausblenden")" @onclick="ToggleSpriteGrid"><span class="material-symbols-rounded">grid_on</span></button>
                                    <label title="@T("Logical grid cell size", "Größe der logischen Rasterzelle")"><select value="@spriteGridSize" @onchange="ChangeSpriteGridSize" aria-label="@T("Grid cell size", "Rasterzellengröße")"><option value="1">1×</option><option value="2">2×</option><option value="3">3×</option><option value="4">4×</option><option value="8">8×</option></select></label>
                                </div>
                                <button class="sprite-icon-button seamless-preview-button @(spriteSeamlessPreview ? "active" : "")" aria-label="@T("Seamless pattern preview", "Nahtlose Mustervorschau")" title="@T("Show the sprite as a seamless 3×3 pattern", "Sprite als nahtloses 3×3-Muster anzeigen")" aria-pressed="@spriteSeamlessPreview" @onclick="ToggleSpriteSeamlessPreview"><span class="seamless-preview-icon" aria-hidden="true"><i></i><i></i><i></i><i></i><i class="center"></i><i></i><i></i><i></i><i></i></span></button>
                                <button class="sprite-icon-button" aria-label="@T("Settings", "Einstellungen")" title="@T("Settings", "Einstellungen")" @onclick="() => showSettings = true"><span class="material-symbols-rounded">settings</span></button>
                                <button class="sprite-icon-button sprite-export-button" aria-label="@T("Export sprite", "Sprite exportieren")" title="@T("Export current sprite", "Aktuellen Sprite exportieren")" @onclick="OpenSpriteExportDialog" disabled="@(StudioAsset is null)"><span class="material-symbols-rounded">file_download</span><small>@T("Export", "Export")</small></button>
                            </div>
                            @if (StudioAsset is not null && (StudioAsset.Width != SpriteTilePixels || StudioAsset.Height != SpriteTilePixels)) { <div class="ai-size-warning"><span>AI</span><p>@T("AI drawing currently works on one 48×48 tile. Multi-tile sprites remain fully editable by hand.", "KI-Zeichnen arbeitet aktuell auf einer 48×48-Kachel. Mehrkachel-Sprites bleiben vollständig manuell bearbeitbar.")</p><button @onclick="CreateAiSizedCopy">@T("Create 1×1 tile copy", "1×1-Kachel-Kopie anlegen")</button></div> }
                            @if (StudioAsset is null)
                            {
                                <div class="studio-empty"><strong>@T("Select a sprite", "Sprite auswählen")</strong><span>@T("Choose an asset from the library to edit it.", "Wähle ein Asset aus der Bibliothek, um es zu bearbeiten.")</span></div>
                            }
                            else
                            {
                                <div class="sprite-editor-body">
                                    <aside class="sprite-brush-panel">
                                        <section><h2>@T("Brush", "Pinsel")</h2><div class="brush-preview"><span style="--brush-preview:@BrushPreviewSize"></span></div>@foreach (var size in BrushSizePresets) { <button class="brush-preset @(spriteBrushSize == size ? "active" : "")" @onclick="() => SetSpriteBrushSize(size)"><span style="--brush-dot:@BrushDotSize(size)"></span><strong>@size<span>px</span></strong></button> }</section>
                                        <section class="brush-color-card"><h2>@T("Color", "Farbe")</h2><div class="dual-color-picker"><label class="primary-color" style="--picker-color:@spriteColor" title="@T("Left mouse button color", "Farbe der linken Maustaste")"><input type="color" value="@spriteColor" @onchange="ChangeSpriteColor" aria-label="@T("Left mouse button color", "Farbe der linken Maustaste")" /></label><label class="secondary-color" style="--picker-color:@spriteSecondaryColor" title="@T("Right mouse button color", "Farbe der rechten Maustaste")"><input type="color" value="@spriteSecondaryColor" @onchange="ChangeSpriteSecondaryColor" aria-label="@T("Right mouse button color", "Farbe der rechten Maustaste")" /></label></div><div class="mouse-color-hints"><span><i></i>@T("Left", "Links")</span><span><i></i>@T("Right", "Rechts")</span></div><button class="swap-color" aria-label="@T("Swap colors", "Farben tauschen")" title="@T("Swap left and right mouse colors", "Farben der linken und rechten Maustaste tauschen")" @onclick="SwapSpriteColors"><span class="material-symbols-rounded">swap_horiz</span></button></section>
                                    </aside>
                                    <div class="sprite-canvas-column"><div class="sprite-editor-title"><strong>@StudioAsset.FileName</strong><span>@SpriteTileSizeLabel(StudioAsset) · @MaterialChannelLabel(activeMaterialChannel)</span></div><div class="sprite-canvas-shell"><canvas id="spriteEditorCanvas" aria-label="@T("Pixel editor", "Pixel-Editor")"></canvas>@if (spriteTool == "select") { <div class="selection-command-bar" role="toolbar" aria-label="@T("Selection actions", "Auswahlaktionen")"><button title="Ctrl/Cmd+A" @onclick="SelectAllSpritePixels"><span class="material-symbols-rounded">select_all</span>@T("All", "Alles")</button><button title="@T("Ctrl/Cmd+C · Attach to cursor until Esc", "Ctrl/Cmd+C · Bis Esc am Cursor")" @onclick="CopySpriteSelection"><span class="material-symbols-rounded">content_copy</span>@T("Copy", "Kopieren")</button><button title="@T("Ctrl/Cmd+X · Attach to cursor until Esc", "Ctrl/Cmd+X · Bis Esc am Cursor")" @onclick="CutSpriteSelection"><span class="material-symbols-rounded">content_cut</span>@T("Cut", "Ausschneiden")</button><button class="danger" title="Backspace / Delete" @onclick="DeleteSpriteSelection"><span class="material-symbols-rounded">delete</span>@T("Delete", "Löschen")</button><button title="Esc" @onclick="ClearSpriteSelection"><span class="material-symbols-rounded">deselect</span>@T("Cancel", "Abbrechen")</button></div> }@if (aiSpriteDrawing) { <div class="ai-drawing-badge"><span class="material-symbols-rounded">auto_awesome</span><strong>@T("AI is drawing…", "KI zeichnet…")</strong></div> }</div></div>
                                    <aside class="sprite-color-panel">
                                        @if (activeMaterialChannel == MaterialChannel.Lit)
                                        {
                                            <div class="palette-heading"><strong>@T("Preview mode", "Vorschaumodus")</strong><small>@T("Move the pointer over the canvas to position the light. Fine-tune the material with the controls on the right.", "Bewege den Mauszeiger über die Zeichenfläche, um das Licht zu positionieren. Das Material stellst du rechts fein ein.")</small></div>
                                        }
                                        else
                                        {
                                            <div class="palette-heading"><strong>@T("Palette", "Palette")</strong><small>@PaletteHint</small></div><div class="palette-actions"><button aria-label="@T("Add current color to palette", "Aktuelle Farbe zur Palette hinzufügen")" title="@T("Add the large left-click color", "Die große Linksklick-Farbe hinzufügen")" @onclick="AddCurrentColorToPalette"><span class="material-symbols-rounded">add</span></button><button aria-label="@T("Remove selected color", "Ausgewählte Farbe entfernen")" title="@T("Remove the selected left-click color", "Die ausgewählte Linksklick-Farbe entfernen")" @onclick="RequestDeletePaletteColor" disabled="@(!ActiveSpritePalette.Contains(spriteColor, StringComparer.OrdinalIgnoreCase))"><span class="material-symbols-rounded">remove</span></button></div><div class="palette-grid" aria-label="@T("Color palette: left click selects the large color, right click selects the small color", "Farbpalette: Linksklick wählt die große Farbe, Rechtsklick die kleine Farbe")">@foreach (var color in ActiveSpritePalette) { <button class="@(PaletteColorCss(color))" style="background:@color" aria-label="@color" title="@T("Left click: primary · Right click: secondary", "Linksklick: Hauptfarbe · Rechtsklick: Nebenfarbe")" @onclick="() => PickPaletteColor(color)" @oncontextmenu="() => PickPaletteSecondaryColor(color)" @oncontextmenu:preventDefault="true"></button> }</div><label class="palette-hex"><span>#</span><input value="@spriteColor.TrimStart('#').ToUpperInvariant()" maxlength="6" @onchange="ChangeSpriteHex" aria-label="@T("Hex color", "Hex-Farbe")" /></label>
                                        }
                                    </aside>
                                </div>
                            }
                        </main>

                        <aside class="studio-inspector">
                            @if (StudioAsset is not null)
                            {
                                <section class="sprite-status-section">
                                    <div><span>@T("Sprite status", "Sprite-Status")</span><strong>@(StudioAsset.NormalMapStatus == DerivedAssetStatus.Ready ? T("Finished material", "Fertiges Material") : T("Material in progress", "Material in Bearbeitung"))</strong></div>
                                    <button class="@(StudioAsset.NormalMapStatus == DerivedAssetStatus.Ready ? "ready" : "not-ready")" @onclick="FinalizeStudioSprite" disabled="@(State.IsBusy || StudioAsset.NormalMapStatus == DerivedAssetStatus.Ready)" title="@(StudioAsset.NormalMapStatus == DerivedAssetStatus.Ready ? T("This sprite is ready", "Dieser Sprite ist fertig") : T("Finish sprite and mark Ready", "Sprite fertigstellen und auf Ready setzen"))"><span class="material-symbols-rounded">@(StudioAsset.NormalMapStatus == DerivedAssetStatus.Ready ? "task_alt" : "pending")</span>@(StudioAsset.NormalMapStatus == DerivedAssetStatus.Ready ? T("Ready", "Bereit") : T("Not ready", "Nicht bereit"))</button>
                                </section>
                                <div class="material-channel-scroll">
                                    <div class="material-list-heading"><strong>@T("Material", "Material")</strong><span>@T("Texture channels", "Texturkanäle")</span></div>
                                    @foreach (var channel in MaterialChannels)
                                    {
                                        <div class="material-channel-item @(activeMaterialChannel == channel ? "active" : "")">
                                            <button class="material-channel-summary" @onclick="() => SetMaterialChannel(channel)" aria-expanded="@(activeMaterialChannel == channel)">
                                                <img src="@MaterialThumbnail(StudioAsset, channel)" alt="" />
                                                <span><strong>@MaterialChannelLabel(channel)</strong><small>@MaterialChannelState(StudioAsset, channel)</small></span>
                                                <span class="material-symbols-rounded">@(activeMaterialChannel == channel ? "expand_less" : "expand_more")</span>
                                            </button>
                                            @if (activeMaterialChannel == channel)
                                            {
                                                <div class="material-channel-controls">
                                                    @if (channel == MaterialChannel.Base) { <label class="sprite-world-use"><span>@T("World use", "Verwendung in der Welt")</span><select value="@StudioAssetWorldUse" @onchange="ChangeStudioAssetWorldUse"><option value="Element">@T("Element · optionally free", "Element · optional frei")</option><option value="Floor">@T("Floor · always on grid", "Boden · immer im Raster")</option><option value="Wall">@T("Wall · always on grid", "Wand · immer im Raster")</option></select></label><p>@T("Edit the base color and silhouette in the main canvas. Floor and wall sprites always snap to the 48 px world grid.", "Bearbeite Grundfarbe und Silhouette im großen Canvas. Boden- und Wand-Sprites rasten immer im 48-px-Weltraster ein.")</p> }
                                                    else if (channel == MaterialChannel.Normal) { <label>@T("Normal strength", "Normal-Stärke")<output>@StudioAsset.NormalStrength.ToString("0.0")</output></label><input class="wide-range" type="range" min="0.1" max="4" step="0.1" value="@StudioAsset.NormalStrength" @oninput="ChangeNormalStrength" /><label class="switch-row">@T("Invert Y", "Y invertieren")<input type="checkbox" checked="@StudioAsset.NormalInvertY" @onchange="ChangeNormalInvertY" /></label><button class="button full" @onclick="() => GenerateNormalForAsset(StudioAsset)" disabled="@State.IsBusy">↻ @(StudioAsset.NormalMapUrl is null ? T("Generate normal", "Normal Map generieren") : T("Regenerate normal", "Normal Map neu generieren"))</button> }
                                                    else if (channel == MaterialChannel.Metallic) { <label>@T("Metallic influence", "Metallic-Einfluss")<output>@StudioAsset.MetallicStrength.ToString("0.00")</output></label><input class="wide-range" type="range" min="0" max="1" step="0.05" value="@StudioAsset.MetallicStrength" @oninput="ChangeMetallicStrength" /> }
                                                    else if (channel == MaterialChannel.Roughness) { <label>@T("Surface roughness", "Oberflächenrauheit")<output>@StudioAsset.RoughnessStrength.ToString("0.00")</output></label><input class="wide-range" type="range" min="0" max="1" step="0.05" value="@StudioAsset.RoughnessStrength" @oninput="ChangeRoughnessStrength" /> }
                                                    else if (channel == MaterialChannel.Lit) { <label>@T("Normal strength", "Normal-Stärke")<output>@StudioAsset.NormalStrength.ToString("0.0")</output></label><input class="wide-range" type="range" min="0.1" max="4" step="0.1" value="@StudioAsset.NormalStrength" @oninput="ChangeNormalStrength" /><label>@T("Metallic", "Metallic")<output>@StudioAsset.MetallicStrength.ToString("0.00")</output></label><input class="wide-range" type="range" min="0" max="1" step="0.05" value="@StudioAsset.MetallicStrength" @oninput="ChangeMetallicStrength" /><label>@T("Roughness", "Rauheit")<output>@StudioAsset.RoughnessStrength.ToString("0.00")</output></label><input class="wide-range" type="range" min="0" max="1" step="0.05" value="@StudioAsset.RoughnessStrength" @oninput="ChangeRoughnessStrength" /><label>@T("Light intensity", "Lichtstärke")<output>@StudioAsset.LightIntensity.ToString("0.0")</output></label><input class="wide-range" type="range" min="0.1" max="3" step="0.1" value="@StudioAsset.LightIntensity" @oninput="ChangeLightIntensity" /> }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                                <section class="lit-preview-section pinned-lit-preview"><div class="inspector-section-title"><h3>@T("Lit preview", "Beleuchtete Vorschau")</h3><button class="lighting-toggle @(spriteLighting ? "active" : "")" @onclick="ToggleSpriteLighting" aria-pressed="@spriteLighting">☼ @(spriteLighting ? T("Light on", "Licht an") : T("Light off", "Licht aus"))</button></div><div class="lit-preview-shell"><canvas id="spriteLitCanvas" aria-label="@T("Material lighting preview", "Material-Lichtvorschau")"></canvas></div></section>
                            }
                        </aside>
                    }
                    else if (SelectedLibraryProject is { } selectedProject)
                    {
                        <main class="project-library-preview" aria-label="@T("Selected world preview", "Vorschau der ausgewählten Welt")">
                            <div class="project-library-preview-stage"><img src="@ProjectPreviewUrl(selectedProject)" alt="@T("World preview", "Weltenvorschau") @LocalizedProjectName(selectedProject.Name)" /></div>
                            <div class="project-library-preview-footer">
                                <div><span class="eyebrow">@T("SELECTED WORLD", "AUSGEWÄHLTE WELT")</span><h2>@LocalizedProjectName(selectedProject.Name)</h2><p>@LocalizedDate(selectedProject.UpdatedAt) · @T("Click the selected card again or use the button to open it.", "Klicke die ausgewählte Karte erneut oder nutze den Button zum Öffnen.")</p></div>
                                <button class="button primary project-open-button" @onclick="() => OpenProjectFromLibrary(selectedProject.Id)"><span class="material-symbols-rounded">arrow_forward</span>@T("Open world", "Welt öffnen")</button>
                            </div>
                        </main>
                    }
                    else
                    {
                        <main class="project-library-hero brand-hero"><div><img class="world-library-logo" src="/sprite2world-logo.png" alt="Sprite2World" /><p>@T("Select a world on the left to see its preview. A second click opens it.", "Wähle links eine Welt aus, um ihre Vorschau zu sehen. Ein zweiter Klick öffnet sie.")</p><button class="button primary" @onclick="CreateProjectFromLibrary">＋ @T("New world", "Neue Welt")</button></div></main>
                    }
                </div>
            </section>
        }

        @if (showSpriteSetupDialog)
        {
            <div class="modal-backdrop sprite-setup-backdrop" @onclick="() => showSpriteSetupDialog = false">
                <div class="settings-modal panel sprite-setup-modal" role="dialog" aria-modal="true" aria-labelledby="sprite-setup-title" @onkeydown="HandleSpriteSetupKey" @onclick:stopPropagation="true">
                    <div class="modal-heading"><div><span class="eyebrow">@(spriteSetupImport ? T("IMPORT SPRITES", "SPRITES IMPORTIEREN") : T("NEW SPRITE", "NEUES SPRITE"))</span><h2 id="sprite-setup-title">@T("Choose a bounded canvas", "Begrenzte Canvas-Größe wählen")</h2></div><button class="icon-button" aria-label="@T("Close", "Schließen")" @onclick="() => showSpriteSetupDialog = false">×</button></div>
                    <section>
                        @if (!spriteSetupImport) { <label>@T("Name", "Name")<input @bind="newSpriteName" @bind:event="oninput" maxlength="64" /></label> }
                        <div class="size-preset-row">@foreach (var size in SpriteTilePresets) { <button class="@(newSpriteTilesWide == size.Width && newSpriteTilesHigh == size.Height ? "active" : "")" @onclick="() => SetSpriteTileSize(size.Width, size.Height)">@size.Width × @size.Height @T("tiles", "Kacheln")</button> }</div>
                        <div class="sprite-size-fields tile-unit-fields"><label>@T("Tiles wide", "Kacheln breit")<input type="number" min="1" max="8" @bind="newSpriteTilesWide" /></label><span>×</span><label>@T("Tiles high", "Kacheln hoch")<input type="number" min="1" max="8" @bind="newSpriteTilesHigh" /></label></div>
                        <div class="sprite-pixel-result"><span class="material-symbols-rounded">grid_4x4</span><strong>@NewSpritePixelWidth × @NewSpritePixelHeight px</strong><small>@T("Each world tile is exactly 48×48 pixels.", "Jede Weltkachel ist exakt 48×48 Pixel groß.")</small></div>
                        @if (!spriteSetupImport)
                        {
                            <label class="sprite-folder-select"><span><span class="material-symbols-rounded">folder</span>@T("Folder", "Ordner")</span>
                                <select @bind="NewSpriteFolderPath">
                                    @foreach (var themeGroup in NewSpriteFolderChoices.GroupBy(folder => folder.Theme).OrderBy(group => group.Key, StringComparer.OrdinalIgnoreCase))
                                    {
                                        <optgroup label="@FolderDisplayName(themeGroup.Key)">
                                            @foreach (var folder in themeGroup.OrderBy(folder => folder.Subfolder, StringComparer.OrdinalIgnoreCase))
                                            {
                                                <option value="@LibraryFolderPath(folder.Theme, folder.Subfolder)">@FolderDisplayName(folder.Theme) / @folder.Subfolder</option>
                                            }
                                        </optgroup>
                                    }
                                </select>
                            </label>
                        }
                        @if (spriteSetupImport) { <p class="settings-note">@T("Every imported PNG is resized pixel-perfect to the selected 48 px tile footprint.", "Jedes importierte PNG wird pixelgenau auf die gewählte 48-px-Kachelfläche skaliert.")</p> }
                    </section>
                    @if (spriteSetupImport) { <label class="button primary full sprite-file-action">⇧ @T("Choose PNG files", "PNG-Dateien auswählen")<InputFile OnChange="ImportFiles" multiple accept=".png,image/png" /></label> }
                    else { <button class="button primary full sprite-create-action" @onclick="CreateBlankSprite" disabled="@State.IsBusy">＋ @T("Create sprite", "Sprite anlegen")</button> }
                </div>
            </div>
        }

        @if (showDeletePaletteColorDialog && pendingPaletteColor is not null)
        {
            <div class="modal-backdrop palette-delete-backdrop" @onclick="CloseDeletePaletteColorDialog">
                <div class="settings-modal panel palette-delete-modal" role="dialog" aria-modal="true" aria-labelledby="palette-delete-title" @onclick:stopPropagation="true">
                    <div class="modal-heading"><div><span class="eyebrow">@T("COLOR PALETTE", "FARBPALETTE")</span><h2 id="palette-delete-title">@T("Delete color?", "Farbe löschen?")</h2></div><button class="icon-button" aria-label="@T("Close", "Schließen")" @onclick="CloseDeletePaletteColorDialog">×</button></div>
                    <section><div class="palette-delete-color" style="--delete-color:@pendingPaletteColor"></div><div><strong>@pendingPaletteColor.ToUpperInvariant()</strong><p>@T("Do you really want to remove this color from the current palette?", "Möchtest du diese Farbe wirklich aus der aktuellen Palette entfernen?")</p></div></section>
                    <div class="palette-delete-actions"><button class="button" @onclick="CloseDeletePaletteColorDialog">@T("Cancel", "Abbrechen")</button><button class="button danger" @onclick="DeletePaletteColor"><span class="material-symbols-rounded">delete</span>@T("Delete color", "Farbe löschen")</button></div>
                </div>
            </div>
        }

        @if (showAiSpriteDialog && StudioAsset is not null)
        {
            <div class="modal-backdrop ai-sprite-backdrop" @onclick="DiscardAiSprite">
                <div class="settings-modal panel ai-sprite-modal @(aiSuccessPulse ? "ai-magic-success" : "")" role="dialog" aria-modal="true" aria-labelledby="ai-sprite-title" @onkeydown="HandleAiSpriteKey" @onclick:stopPropagation="true">
                    <div class="modal-heading"><div><span class="eyebrow">@T("AI SPRITE ARTIST", "KI-SPRITE-ZEICHNER")</span><h2 id="ai-sprite-title">@T("What should I draw?", "Was soll ich zeichnen?")</h2></div><button class="icon-button" aria-label="@T("Close", "Schließen")" @onclick="DiscardAiSprite">×</button></div>
                    @if (!SpriteAiSizeSupported)
                    {
                        <div class="ai-size-warning ai-size-dialog-warning"><span>AI</span><p>@T($"The selected {SpriteTileSizeLabel(StudioAsset)} sprite is larger than the AI generator limit of 64×64 pixels. Create a linked 1×1 working copy and generate there.", $"Der ausgewählte Sprite mit {SpriteTileSizeLabel(StudioAsset)} ist größer als das KI-Limit von 64×64 Pixeln. Erstelle eine verknüpfte 1×1-Arbeitskopie und generiere dort.")</p><button @onclick="CreateAiSizedCopy">@T("Create 1×1 AI working copy", "1×1-KI-Arbeitskopie erstellen")</button></div>
                    }
                    <section>
                        <label>@T("Description", "Beschreibung")<textarea @bind="aiSpritePrompt" @bind:event="oninput" maxlength="600" placeholder="@T("e.g. a heavy blacksmith hammer with a wooden handle", "z. B. ein schwerer Schmiedehammer mit Holzgriff")"></textarea></label>
                        <div class="ai-art-controls"><label>@T("View", "Ansicht")<select @bind="aiSpriteView"><option>Auto</option><option value="Side">@T("Side", "Seite")</option><option value="Three-quarter">@T("Three-quarter", "Dreiviertel")</option><option value="Front">@T("Front", "Vorne")</option></select></label><label>@T("Framing", "Bildausschnitt")<select @bind="aiSpriteFraming"><option value="Full subject">@T("Full subject", "Ganzes Motiv")</option><option value="Icon">Icon</option><option value="Portrait">@T("Portrait", "Porträt")</option></select></label><label>@T("Outline", "Kontur")<select @bind="aiSpriteOutline"><option value="None">@T("None", "Keine")</option><option value="1 px">1 px</option><option value="2 px">2 px</option></select></label><label>@T("Light", "Licht")<select @bind="aiSpriteLighting"><option value="Top left">@T("Top left", "Oben links")</option><option value="Top right">@T("Top right", "Oben rechts")</option><option value="Front">@T("Front", "Vorne")</option></select></label></div>
                        <label>@T("Palette or style reference", "Palette oder Stilreferenz")<input @bind="aiSpritePaletteHint" @bind:event="oninput" maxlength="160" placeholder="@T("e.g. muted beach palette, match current sprite", "z. B. gedeckte Strandpalette, aktuelles Sprite angleichen")" /></label>
                        <div class="ai-canvas-facts"><span><strong>@StudioAsset.Width × @StudioAsset.Height</strong>@T("Canvas size", "Canvas-Größe")</span><span><strong>16</strong>@T("colors maximum", "Farben maximal")</span><span><strong>PNG</strong>@T("transparent", "transparent")</span></div>
                        <p>@T("By default, AI draws the complete object or full body, keeps outlines and structural lines continuous, and leaves unused cells transparent. Ask explicitly for a portrait or front view only when you want one.", "Standardmäßig zeichnet die KI das vollständige Objekt beziehungsweise den ganzen Körper, hält Konturen und Konstruktionslinien durchgängig und lässt ungenutzte Felder transparent. Bitte nur ausdrücklich um Porträt oder Frontansicht, wenn du das möchtest.")</p>
                        @if (aiSpriteCandidate is not null) { <div class="ai-candidate"><canvas id="aiSpritePreview" aria-label="@T("Generated sprite preview", "Vorschau des generierten Sprites")"></canvas><div><strong>@aiSpriteCandidate.Name</strong><span class="@(aiSpriteCandidate.Quality.Passed ? "quality-pass" : "quality-warning")">@(aiSpriteCandidate.Quality.Passed ? T("Automatic checks passed", "Automatische Prüfungen bestanden") : T("Check the highlighted quality notes", "Markierte Qualitätshinweise prüfen"))</span>@foreach (var issue in aiSpriteCandidate.Quality.Issues) { <small>• @issue.Message</small> }</div></div> }
                    </section>
                    @if (aiRequestActive)
                    {
                        <div class="ai-communication-status" role="status" aria-live="polite" aria-label="@T("OpenAI request activity", "OpenAI-Anfrageaktivität")">
                            <div class="ai-transmission-card">
                                <span class="material-symbols-rounded" aria-hidden="true">outgoing_mail</span>
                                <div><small>@T("REQUEST SENT", "ANFRAGE GESENDET")</small><strong>OpenAI</strong><p>@T("Your sprite brief is on its way.", "Dein Sprite-Briefing ist unterwegs.")</p></div>
                            </div>
                            <div class="ai-activity-console">
                                <header><span></span><small>@T("LIVE ACTIVITY", "LIVE-AKTIVITÄT")</small><i>@T("working", "arbeitet")</i></header>
                                <code><span>&gt; @T("request accepted", "Anfrage angenommen")</span><span>&gt; @aiProgressStep</span><span class="ai-console-wait">&gt; @T("waiting for model response", "warte auf Modellantwort")<b aria-hidden="true">•••</b></span></code>
                            </div>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(aiProgressStep))
                    {
                        <div class="ai-operation-status @(aiProgressFailed ? "failed" : aiProgressSpinning ? "working" : "complete")" aria-live="polite">
                            @if (aiProgressSpinning) { <span class="ai-step-spinner" aria-hidden="true"></span> }
                            else { <span class="material-symbols-rounded ai-step-check" aria-hidden="true">@(aiProgressFailed ? "error" : "check_circle")</span> }
                            <div><small>@T(aiProgressFailed ? "ERROR" : "CURRENT STEP", aiProgressFailed ? "FEHLER" : "AKTUELLER SCHRITT")</small><strong>@aiProgressStep</strong>@if (!string.IsNullOrWhiteSpace(aiProgressDetail)) { <p>@aiProgressDetail</p> }</div>
                        </div>
                    }
                    @if (aiSpriteCandidate is null && !aiRequestActive && !State.IsBusy) { <button class="button primary full ai-generate-action" @onclick="GenerateAiSprite" disabled="@(!Credentials.IsReady || !SpriteAiSizeSupported || string.IsNullOrWhiteSpace(aiSpritePrompt))"><span class="material-symbols-rounded">auto_awesome</span>AI</button> }
                    else if (aiRequestActive || State.IsBusy) { <div class="ai-candidate-actions ai-busy-actions"><button class="button danger" @onclick="CancelAiSprite">@T("Cancel", "Abbrechen")</button></div> }
                    else { <div class="ai-candidate-actions"><button class="button" @onclick="DiscardAiSprite">@T("Discard", "Verwerfen")</button><button class="button" @onclick="GenerateAiSprite" disabled="@(State.IsBusy || !Credentials.IsReady || !SpriteAiSizeSupported)">@T("New variant", "Neue Variante")</button><button class="button primary" @onclick="AcceptAiSprite">@T("Apply", "Übernehmen")</button></div> }
                </div>
            </div>
        }

        @if (showCreateFolderDialog)
        {
            <div class="modal-backdrop asset-manager-backdrop" @onclick="CloseCreateFolderDialog">
                <div class="settings-modal panel asset-manager-modal folder-create-modal" role="dialog" aria-modal="true" aria-labelledby="folder-create-title" @onclick:stopPropagation="true">
                    <div class="modal-heading"><div><span class="eyebrow">@T("SPRITE LIBRARY", "SPRITE-BIBLIOTHEK")</span><h2 id="folder-create-title">@T("Create folder", "Ordner anlegen")</h2></div><button class="icon-button" aria-label="@T("Close", "Schließen")" @onclick="CloseCreateFolderDialog">×</button></div>
                    <section class="asset-folder-picker">
                        <h3>@T("Existing structure", "Vorhandene Struktur")</h3>
                        <div class="asset-folder-tree" role="tree">
                            @foreach (var themeGroup in LibraryFolders.GroupBy(folder => folder.Theme).OrderBy(group => group.Key, StringComparer.OrdinalIgnoreCase))
                            {
                                <div class="asset-folder-tree-group" role="treeitem" aria-expanded="true"><button class="folder-theme-choice @(newFolderTheme == themeGroup.Key && string.IsNullOrWhiteSpace(newFolderSubfolder) ? "active" : "")" @onclick="() => SelectNewFolderTheme(themeGroup.Key)"><span class="material-symbols-rounded">folder_open</span><strong>@FolderDisplayName(themeGroup.Key)</strong></button>
                                    @foreach (var folder in themeGroup.OrderBy(folder => folder.Subfolder, StringComparer.OrdinalIgnoreCase))
                                    {
                                        <button @onclick="() => SelectNewFolderParent(themeGroup.Key, folder.Subfolder)"><span class="material-symbols-rounded">subdirectory_arrow_right</span><strong>@folder.Subfolder</strong></button>
                                    }
                                </div>
                            }
                        </div>
                        <div class="asset-folder-custom"><label>@T("Theme", "Thema")<input autofocus @bind="newFolderTheme" @bind:event="oninput" maxlength="40" placeholder="@T("e.g. Beach", "z. B. Strand")" /></label><label>@T("Subfolder (optional)", "Unterordner (optional)")<input @bind="newFolderSubfolder" @bind:event="oninput" maxlength="40" placeholder="@T("e.g. Decoration", "z. B. Dekoration")" /></label></div>
                        <p class="settings-note">@T("Without a subfolder, a default “Sprites” folder is created. Empty folders remain in the project.", "Ohne Unterordner wird ein Standardordner „Sprites“ angelegt. Leere Ordner bleiben im Projekt erhalten.")</p>
                    </section>
                    <button class="button primary full" @onclick="CreateLibraryFolder" disabled="@string.IsNullOrWhiteSpace(newFolderTheme)">＋ @T("Create folder", "Ordner anlegen")</button>
                </div>
            </div>
        }

        @if (showAssetManagerDialog && ManagedLibraryAsset is not null)
        {
            <div class="modal-backdrop asset-manager-backdrop" @onclick="CloseAssetManager">
                <div class="settings-modal panel asset-manager-modal" role="dialog" aria-modal="true" aria-labelledby="asset-manager-title" @onclick:stopPropagation="true">
                    <div class="modal-heading"><div><span class="eyebrow">@T("SPRITE LIBRARY", "SPRITE-BIBLIOTHEK")</span><h2 id="asset-manager-title">@(assetManagerMode == "rename" ? T("Rename sprite", "Sprite umbenennen") : T("Move sprite", "Sprite verschieben"))</h2></div><button class="icon-button" aria-label="@T("Close", "Schließen")" @onclick="CloseAssetManager">×</button></div>
                    <section class="asset-manager-summary"><img src="@ManagedLibraryAsset.Url" alt="" /><div><strong>@ManagedLibraryAsset.FileName</strong><small>@ManagedLibraryAsset.Width×@ManagedLibraryAsset.Height · @FolderDisplayName(AssetThemeKey(ManagedLibraryAsset)) / @AssetSubfolder(ManagedLibraryAsset)</small></div></section>
                    @if (assetManagerMode == "rename")
                    {
                        <section><label>@T("New name", "Neuer Name")<input autofocus @bind="assetManagerName" @bind:event="oninput" maxlength="72" /></label><p class="settings-note">@T("The PNG extension is kept automatically.", "Die PNG-Endung bleibt automatisch erhalten.")</p></section>
                    }
                    else
                    {
                        <section class="asset-folder-picker">
                            <h3>@T("Choose destination", "Zielordner auswählen")</h3>
                            <div class="asset-folder-tree" role="tree">
                                @foreach (var themeGroup in LibraryFolders.GroupBy(folder => folder.Theme).OrderBy(group => group.Key, StringComparer.OrdinalIgnoreCase))
                                {
                                    <div class="asset-folder-tree-group" role="treeitem" aria-expanded="true"><div><span class="material-symbols-rounded">folder_open</span><strong>@FolderDisplayName(themeGroup.Key)</strong></div>
                                        @foreach (var folder in themeGroup.OrderBy(folder => folder.Subfolder, StringComparer.OrdinalIgnoreCase))
                                        {
                                            var folderAssetCount = State.Assets.Count(asset => string.Equals(AssetThemeKey(asset), themeGroup.Key, StringComparison.OrdinalIgnoreCase) && string.Equals(AssetSubfolder(asset), folder.Subfolder, StringComparison.OrdinalIgnoreCase));
                                            <button class="@(assetManagerTheme == themeGroup.Key && assetManagerSubfolder == folder.Subfolder ? "active" : "")" @onclick="() => SelectAssetManagerFolder(themeGroup.Key, folder.Subfolder)"><span class="material-symbols-rounded">folder</span><strong>@folder.Subfolder</strong><small>@folderAssetCount</small></button>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="asset-folder-custom"><label>@T("Theme", "Thema")<input @bind="assetManagerTheme" @bind:event="oninput" maxlength="40" /></label><label>@T("Subfolder", "Unterordner")<input @bind="assetManagerSubfolder" @bind:event="oninput" maxlength="40" /></label></div>
                        </section>
                    }
                    <button class="button primary full" @onclick="SaveAssetManager" disabled="@(assetManagerMode == "rename" ? string.IsNullOrWhiteSpace(assetManagerName) : string.IsNullOrWhiteSpace(assetManagerTheme) || string.IsNullOrWhiteSpace(assetManagerSubfolder))">@(assetManagerMode == "rename" ? T("Save name", "Namen speichern") : T("Move sprite", "Sprite verschieben"))</button>
                </div>
            </div>
        }

        <aside class="asset-panel panel @(assetPanelCollapsed ? "panel-collapsed" : "") @(assetPanelFloating ? "floating-panel assets-floating" : "")">
            <div class="panel-heading"><div><span class="eyebrow">@T("ASSET LIBRARY", "ASSET-BIBLIOTHEK")</span><strong>@State.Assets.Count.ToString("N0") @T("sprites", "Sprites")</strong></div><div class="panel-controls"><button class="tiny-button" @onclick="State.LoadDemoAsync" disabled="@State.IsBusy">@T("Starter pack", "Starterpaket")</button><button class="tiny-button" title="@T("Undock", "Abdocken")" @onclick="ToggleAssetFloating">◲</button><button class="tiny-button" title="@T("Minimize", "Minimieren")" @onclick="() => assetPanelCollapsed = true">—</button></div></div>
            <div class="asset-actions">
                <label class="button primary compact" title="@T("Select up to 10,000 PNG files or ZIP archives", "Bis zu 10.000 PNG-Dateien oder ZIP-Archive auswählen")">⇧ @T("Import many", "Mehrfachimport")<InputFile OnChange="ImportFiles" multiple accept=".png,.zip,image/png,application/zip" /></label>
                <button class="button compact" @onclick="State.ClassifyAsync" disabled="@(!Credentials.IsReady || State.IsBusy || State.Assets.Count == 0)" title="@(Credentials.IsReady ? T("Classify imported sprites with AI", "Importierte Sprites mit AI klassifizieren") : T("Add a valid API key in Settings first", "Zuerst einen gültigen API-Schlüssel in den Einstellungen hinterlegen"))">✦ AI</button>
            </div>
            <div class="search-row"><span>⌕</span><input placeholder="@T("Search assets…", "Assets suchen…")" @bind="assetSearch" @bind:event="oninput" /></div>
            <div class="filter-row">
                <select @bind="roleFilter"><option value="">@T("All standard categories", "Alle Standard-Rubriken")</option>@foreach (var role in Enum.GetValues<AssetRole>()) { <option value="@role">@RoleLabel(role)</option> }</select>
            </div>
            @if (selectedAssetIds.Count > 0)
            {
                <div class="asset-selection-bar"><strong>@selectedAssetIds.Count.ToString("N0") @T("selected", "ausgewählt")</strong><button @onclick="ClearAssetSelection">@T("Clear", "Leeren")</button><button class="remove-selected" @onclick="RemoveSelectedAssets">@T("Delete", "Löschen")</button><div class="category-assignment"><input placeholder="@T("Category, e.g. Beach", "Rubrik, z. B. Strand")" @bind="newCategoryName" @bind:event="oninput" /><button @onclick="AssignCategory">@T("Set category", "Rubrik setzen")</button></div></div>
            }
            <div class="asset-scroll">
                @foreach (var category in VisibleAssets.GroupBy(a => string.IsNullOrWhiteSpace(a.Category) ? T("General", "Allgemein") : LocalizedCategory(a.Category)).OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase))
                {
                    <section class="asset-category">
                        <div class="category-title"><span>▾</span><strong>@category.Key</strong><small>@category.Count().ToString("N0")</small></div>
                        @foreach (var roleGroup in category.GroupBy(a => a.Role).OrderBy(g => g.Key.ToString()))
                        {
                            <div class="asset-group">
                                <div class="group-title"><span>@RoleLabel(roleGroup.Key)</span><span>@roleGroup.Count()</span></div>
                                <div class="asset-grid">
                                    @foreach (var asset in roleGroup)
                                    {
                                        <article class="asset-card @(asset.Excluded ? "excluded" : "") @(selectedAssetIds.Contains(asset.Id) ? "selected" : "") @(brushAssetId == asset.Id ? "brush" : "")" draggable="true" data-drag-asset="@asset.Id" @key="asset.Id" title="@asset.RelativePath · @asset.Width×@asset.Height · @LocalizedClassificationSource(asset.ClassificationSource)">
                                            <div class="sprite-wrap" @onclick="() => SelectBrush(asset)"><input class="asset-select" type="checkbox" aria-label="@T("Select", "Auswählen") @asset.FileName" checked="@selectedAssetIds.Contains(asset.Id)" @onchange="e => ToggleAssetSelection(asset.Id, (bool)(e.Value ?? false))" @onclick:stopPropagation="true" /><button class="asset-remove" title="@T("Remove", "Entfernen") @asset.FileName" aria-label="@T("Remove", "Entfernen") @asset.FileName" @onclick="() => RemoveAsset(asset)" @onclick:stopPropagation="true">×</button><img src="@asset.Url" alt="@asset.FileName" loading="lazy" /><span class="confidence">@(brushAssetId == asset.Id ? T("SELECTED", "AUSGEWÄHLT") : $"{Math.Round(asset.Confidence * 100)}%")</span></div>
                                            <div class="asset-name">@asset.FileName</div>
                                            <select value="@asset.Role" @onchange="e => ChangeRole(asset, e)">@foreach (var role in Enum.GetValues<AssetRole>()) { <option value="@role">@RoleLabel(role)</option> }</select>
                                            <label class="exclude-check"><input type="checkbox" checked="@asset.Excluded" @onchange="e => State.SetExcluded(asset, (bool)(e.Value ?? false))" /> @T("exclude", "ausschließen")</label>
                                        </article>
                                    }
                                </div>
                            </div>
                        }
                    </section>
                }
                @if (FilteredAssetCount > visibleAssetLimit) { <button class="button full load-assets" @onclick="ShowMoreAssets">@T("Show", "Weitere") @Math.Min(AssetPageSize, FilteredAssetCount - visibleAssetLimit).ToString("N0") @T("more", "anzeigen") · @FilteredAssetCount.ToString("N0") @T("total", "gesamt")</button> }
            </div>
        </aside>

        <section class="workspace panel @(promptCollapsed ? "prompt-collapsed" : "")">
            <div class="workspace-tabs" role="toolbar" aria-label="@T("Canvas tools", "Canvas-Werkzeuge")">
                <div class="canvas-tools">
                    <button class="tool-button @(editorTool == "pan" ? "active" : "")" @onclick='() => SetEditorTool("pan")' title="@T("Pan canvas", "Canvas verschieben")">✋ @T("Hand", "Hand")</button>
                    <button class="tool-button @(editorTool == "draw" ? "active" : "")" @onclick='() => SetEditorTool("draw")' title="@T("Activate drawing mode and select a sprite", "Zeichenmodus aktivieren und Sprite wählen")">✎ @T("Draw", "Zeichnen")</button>
                    <button class="tool-button @(editorTool == "erase" ? "active" : "")" @onclick='() => SetEditorTool("erase")' title="@T("Remove elements from the active layer", "Elemente auf der aktiven Ebene entfernen")">⌫ @T("Eraser", "Radierer")</button>
                    <button class="tool-button @(showGrid ? "active" : "")" @onclick="ToggleGrid">@T("Grid", "Raster")</button>
                    <button class="tool-button snap-elements @(snapElementsToGrid ? "active" : "")" @onclick="ToggleElementSnap" aria-pressed="@snapElementsToGrid" title="@T("Toggle grid snapping for elements. Floor and wall always stay snapped.", "Rasterfang für Elemente umschalten. Boden und Wand bleiben immer eingerastet.")"><span class="material-symbols-rounded world-tool-icon">@(snapElementsToGrid ? "grid_4x4" : "grid_off")</span>@(snapElementsToGrid ? T("Elements snap", "Elemente rasten") : T("Elements free", "Elemente frei"))</button>
                    <button class="tool-button light-tool @(worldLightingEnabled && editorTool == "light-cursor" ? "active" : "")" @onclick="ToggleWorldCursorLight" title="@T("Use the cursor as a movable light", "Cursor als bewegliches Licht verwenden")"><span class="material-symbols-rounded world-tool-icon">light_mode</span>@T("Cursor light", "Cursor-Licht")</button>
                    <button class="tool-button light-tool @(editorTool == "light-place" ? "active" : "")" @onclick="ActivateWorldLightPlacement" title="@T("Place or remove lights on the grid", "Lichter auf dem Raster platzieren oder entfernen")"><span class="material-symbols-rounded world-tool-icon">add_circle</span>@T("Place light", "Licht setzen")</button>
                    <button class="tool-button light-clear" @onclick="DisableWorldLighting" title="@T("Turn off lighting and show the world normally", "Beleuchtung ausschalten und Welt normal anzeigen")"><span class="material-symbols-rounded world-tool-icon">light_off</span></button>
                    <button class="tool-button" @onclick="ZoomOut" title="@T("Zoom out toward the last pointer position", "Zur letzten Mausposition herauszoomen")">−</button><span>@Math.Round(zoom * 100)%</span><button class="tool-button" @onclick="ZoomIn" title="@T("Zoom in toward the last pointer position", "Zur letzten Mausposition hineinzoomen")">＋</button>
                    <button class="tool-button" @onclick="FitCanvas">@T("Fit", "Einpassen")</button>
                    <span class="world-toolbar-divider"></span>
                    <button class="tool-button world-action @(!layersCollapsed ? "active" : "")" @onclick="ToggleLayers" title="@T("Toggle world layers", "Welt-Ebenen ein- oder ausblenden")">▤ @T("Layers", "Ebenen")</button>
                    <button class="tool-button world-action" @onclick="OpenWorldExportDialog" disabled="@(State.World is null)" title="@T("Export world", "Welt exportieren")">⇩ @T("Export", "Export")</button>
                </div>
            </div>

            <div class="workspace-content">
                <div class="canvas-stage @(activeTab == "Playtest" ? "play-mode" : "") tool-@editorTool">
                    <canvas id="worldCanvas" tabindex="0" aria-label="@T("Generated playable world", "Generierte spielbare Welt")"></canvas>
                    @if (editorTool == "draw" && BrushAsset is not null) { <div class="brush-badge"><img src="@BrushAsset.Url" alt="" /><span><strong>@T("Drawing", "Zeichnen")</strong>@BrushAsset.FileName</span></div> }
                    else if (editorTool == "draw") { <div class="brush-badge brush-empty"><span><strong>@T("Drawing mode active", "Zeichenmodus aktiv")</strong>@T("Select a sprite from the library", "Sprite in der Bibliothek auswählen")</span></div> }
                    @if (State.World is null) { <div class="empty-state"><div class="empty-icon">◇</div><h2>@T("Your world starts here", "Deine Welt beginnt hier")</h2><p>@T("Import sprites or use the original demo pack, then generate a playable level.", "Importiere Sprites oder nutze das Demo-Paket und generiere anschließend ein spielbares Level.")</p><button class="button primary" @onclick="() => State.GenerateAsync(false)" disabled="@(!State.HasOpenProject)">@T("Generate demo world", "Demo-Welt generieren")</button></div> }
                    else
                    {
                        <div class="canvas-badge">Seed @State.World.Seed · @State.World.Width×@State.World.Height · @State.World.Regions.Count @WorldRegionLabel</div>
                        @if (activeTab == "Playtest") { <div class="playtest-badge"><strong>@T("PLAYTEST ACTIVE", "TESTLAUF AKTIV")</strong><span>@T("WASD / arrow keys", "WASD / Pfeiltasten")</span></div> }
                        <div class="minimap"><canvas id="miniCanvas"></canvas></div>
                        <div class="play-overlay canvas-playtest-controls">
                            <strong>@T("PLAYTEST", "TESTLAUF")</strong><span>@(activeTab == "Playtest" ? T("WASD / arrow keys", "WASD / Pfeiltasten") : T("Try the world directly", "Welt direkt ausprobieren"))</span>
                            <button @onclick="StartIntegratedPlaytest" disabled="@(activeTab == "Playtest")">▶ @T("Start", "Starten")</button>
                            <button @onclick="ResetPlayer" disabled="@(activeTab != "Playtest")">↺ @T("Reset", "Zurücksetzen")</button>
                            <button @onclick="StopIntegratedPlaytest" disabled="@(activeTab != "Playtest")">■ @T("Stop", "Stoppen")</button>
                        </div>
                    }
                    @if (activeTab != "Playtest")
                    {
                        <button class="world-ai-launch @(!promptCollapsed ? "active" : "")" @onclick="TogglePrompt" aria-expanded="@(!promptCollapsed)" disabled="@(!Credentials.IsReady)" title="@(Credentials.IsReady ? T("Describe and generate the world with AI", "Welt mit KI beschreiben und generieren") : T("Add a valid API key in Settings first", "Zuerst einen gültigen API-Schlüssel in den Einstellungen hinterlegen"))">
                            <span class="material-symbols-rounded">auto_awesome</span>
                            <strong>AI</strong>
                        </button>
                    }
                    @if (worldLightingEnabled && editorTool is "light-cursor" or "light-place")
                    {
                        <aside class="world-light-settings panel" aria-label="@T("Light settings", "Lichteinstellungen")">
                            <header><div><span class="material-symbols-rounded">light_mode</span><strong>@T("Light", "Licht")</strong></div><button aria-label="@T("Close light settings", "Lichteinstellungen schließen")" @onclick="DisableWorldLighting">×</button></header>
                            <label><span>@T("Intensity", "Intensität")</span><output>@worldLightIntensity.ToString("0.0")</output><input type="range" min="0.1" max="3" step="0.1" value="@worldLightIntensity" @oninput="ChangeWorldLightIntensity" /></label>
                            <label><span>@T("Range", "Reichweite")</span><output>@worldLightRange.ToString("0")</output><input type="range" min="3" max="24" step="1" value="@worldLightRange" @oninput="ChangeWorldLightRange" /></label>
                            <label class="world-light-color"><span>@T("Light color", "Lichtfarbe")</span><output>@worldLightColor.ToUpperInvariant()</output><input type="color" value="@worldLightColor" @oninput="ChangeWorldLightColor" /></label>
                            <small>@(editorTool == "light-cursor" ? T("Move the pointer freely over the world.", "Bewege den Cursor stufenlos über die Welt.") : T("Click to place a light; click near it to remove it.", "Klicke zum Setzen; klicke nahe am Licht zum Entfernen."))</small>
                        </aside>
                    }
                </div>
            </div>

            @if (showBlueprintDialog)
            {
                <section class="canvas-dialog panel design-intent-dialog" role="dialog" data-close-on-outside="true" aria-label="@T("Versioned Design Intent", "Versionierte Designabsicht")">
                    <div class="canvas-dialog-heading"><div><span class="eyebrow">@T("VERSIONED DESIGN INTENT", "VERSIONIERTE DESIGNABSICHT")</span><h2>@(State.Blueprint is null ? T("No blueprint", "Kein Entwurf") : LocalizedBlueprintText(State.Blueprint.Theme))</h2></div><div><span class="schema-badge">@T("schema", "Schema") @(State.Blueprint?.SchemaVersion ?? "—")</span><button class="icon-button" aria-label="@T("Close design intent", "Designabsicht schließen")" @onclick="() => showBlueprintDialog = false">×</button></div></div>
                    <div class="canvas-dialog-body">
                        @if (State.Blueprint is not null)
                        {
                            <div class="blueprint-graph">@foreach (var region in State.Blueprint.Regions) { <div class="region-node"><span>@LocalizedBlueprintText(region.Size)</span><strong>@LocalizedBlueprintText(region.Name)</strong><small>@LocalizedBlueprintText(region.Purpose)</small></div> }</div>
                            <pre>@JsonSerializer.Serialize(State.Blueprint, new JsonSerializerOptions(JsonSerializerDefaults.Web) { WriteIndented = true })</pre>
                        }
                    </div>
                </section>
            }

            @if (showChecksDialog)
            {
                <section class="canvas-dialog panel checks-dialog" role="dialog" data-close-on-outside="true" aria-label="@T("Independent Engine Checks", "Unabhängige Engine-Prüfungen")">
                    <div class="canvas-dialog-heading"><div><span class="eyebrow">@T("INDEPENDENT ENGINE CHECKS", "UNABHÄNGIGE ENGINE-PRÜFUNGEN")</span><h2>@(State.Validation?.IsValid == true ? T("World is playable", "Die Welt ist spielbar") : T("Validation needs attention", "Die Prüfung benötigt Aufmerksamkeit"))</h2></div><button class="icon-button" aria-label="@T("Close engine checks", "Engine-Prüfungen schließen")" @onclick="() => showChecksDialog = false">×</button></div>
                    <div class="canvas-dialog-body">
                        <div class="validation-hero @(State.Validation?.IsValid == true ? "valid" : "invalid")"><div class="validation-orb">@(State.Validation?.IsValid == true ? "✓" : "!")</div><div><h2>@(State.Validation?.IsValid == true ? T("All checks passed", "Alle Prüfungen bestanden") : T("Checks need attention", "Prüfungen benötigen Aufmerksamkeit"))</h2><p>@T("Deterministic checks validate the concrete tile map without GPT.", "Deterministische Prüfungen validieren die konkrete Tilemap ohne GPT.")</p></div><button class="button" @onclick="State.ValidateAsync">@T("Run again", "Neu prüfen")</button></div>
                        <div class="check-list">@if (State.Validation is not null) { @foreach (var issue in State.Validation.Issues) { <div class="check-item @(issue.Passed ? "passed" : issue.Severity.ToString().ToLowerInvariant())"><span>@(issue.Passed ? "✓" : "!")</span><div><strong>@issue.CheckId</strong><p>@Localizer.ValidationMessage(issue)</p></div>@if (issue.RepairAvailable) { <em>@T("Auto-repair", "Auto-Reparatur")</em> }</div> } }</div>
                    </div>
                </section>
            }

            <div class="prompt-dock">
                <div class="prompt-copy"><span class="eyebrow">@T("DESCRIBE YOUR WORLD", "BESCHREIBE DEINE WELT")</span><p>@T("First choose the kind of space. The AI then creates connected rooms or outdoor regions.", "Wähle zuerst die Art der Umgebung. Die KI erstellt daraus verbundene Räume oder Außengebiete.")</p><div class="world-kind-picker" role="group" aria-label="@T("World type", "Welttyp")"><button aria-pressed="@(State.WorldEnvironment == "Dungeon" ? "true" : "false")" class="@(State.WorldEnvironment == "Dungeon" ? "active" : "")" @onclick='() => SetWorldEnvironment("Dungeon")'><strong>▦ @T("Dungeon", "Dungeon")</strong><small>@T("Rooms and corridors", "Räume und Korridore")</small></button><button aria-pressed="@(State.WorldEnvironment == "Interior" ? "true" : "false")" class="@(State.WorldEnvironment == "Interior" ? "active" : "")" @onclick='() => SetWorldEnvironment("Interior")'><strong>⌂ @T("Interior", "Innenraum")</strong><small>@T("House, office, rooms", "Haus, Büro, Zimmer")</small></button><button aria-pressed="@(State.WorldEnvironment == "Overworld" ? "true" : "false")" class="@(State.WorldEnvironment == "Overworld" ? "active" : "")" @onclick='() => SetWorldEnvironment("Overworld")'><strong>♧ @T("Overworld", "Oberwelt")</strong><small>@T("Forest, city, outdoors", "Wald, Stadt, draußen")</small></button></div><textarea @bind="State.Prompt" @bind:event="oninput" @bind:after="ScheduleAutoSave" placeholder="@T("Describe rooms or regions, flow, landmarks and pacing…", "Beschreibe Räume oder Gebiete, Verlauf, Landmarken und Tempo…")"></textarea><div class="prompt-chips">@foreach (var chip in WorldPromptChips) { <button @onclick="() => AddPrompt(chip.Value)">@chip.Prefix @chip.Label</button> }</div></div>
                <div class="generation-actions"><button class="button primary generate" @onclick="() => State.GenerateAsync(true)" disabled="@(!Credentials.IsReady || State.IsBusy || !State.HasOpenProject)">✦ @T("Generate world", "Welt generieren")</button><button class="button" @onclick="State.ImproveAsync" disabled="@(!Credentials.IsReady || State.IsBusy || !State.HasOpenProject || State.Blueprint is null)">↻ @T("Improve (feedback)", "Verbessern (Rückmeldung)")</button><div class="inline-feedback"><input @bind="State.Feedback" @bind:event="oninput" @bind:after="ScheduleAutoSave" placeholder="@T("Too linear, too empty…", "Zu linear, zu leer…")" /></div><div class="generation-status"><span class="status-dot @(State.IsBusy ? "busy" : "online")"></span>@StatusText(State.Status)</div></div>
            </div>
        </section>

        <aside class="inspector-column">
            <section class="panel layer-panel @(layersCollapsed ? "panel-collapsed" : "")">
                <div class="panel-heading"><div><span class="eyebrow">@T("LAYERS", "EBENEN")</span><strong>@(State.World?.Layers.Count ?? 0) @T("drawing layers", "Zeichenebenen")</strong></div><div class="panel-controls"><button class="tiny-button" title="@T("Add layer", "Ebene hinzufügen")" @onclick="State.AddLayer" disabled="@(State.World is null)">＋</button><button class="tiny-button" title="@T("Minimize", "Minimieren")" @onclick="() => layersCollapsed = true">—</button></div></div>
                <div class="layer-list">
                    @if (State.World is not null)
                    {
                        @foreach (var layer in State.World.Layers.OrderByDescending(layer => layer.Order))
                        {
                            <div class="layer-row @(State.ActiveLayerId == layer.Id ? "active" : "")" @key="layer.Id">
                                <button class="layer-eye" title="@T("Visibility", "Sichtbarkeit")" @onclick="() => State.ToggleLayerVisibility(layer.Id)">@(layer.Visible ? "◉" : "○")</button>
                                <div class="layer-main" @onclick="() => State.SetActiveLayer(layer.Id)"><input value="@LocalizedLayerName(layer)" readonly="@layer.Locked" aria-label="@T("Rename layer", "Ebene umbenennen") @LocalizedLayerName(layer)" @oninput="e => State.RenameLayer(layer.Id, e.Value?.ToString() ?? string.Empty)" @onclick:stopPropagation="true" /><small>@LayerPurposeLabel(layer) · @layer.Placements.Count.ToString("N0") @T("elements", "Elemente") @(State.ActiveLayerId == layer.Id ? T("· ACTIVE", "· AKTIV") : "")</small></div>
                                <button title="@(layer.Locked ? T("Unlock layer", "Ebene entsperren") : T("Lock layer", "Ebene sperren"))" @onclick="() => State.ToggleLayerLock(layer.Id)">@(layer.Locked ? "🔒" : "🔓")</button>
                                <button title="@T("Bring forward", "Nach vorne")" disabled="@(!CanMoveLayer(layer, 1))" @onclick="() => State.MoveLayer(layer.Id, 1)">↑</button><button title="@T("Send backward", "Nach hinten")" disabled="@(!CanMoveLayer(layer, -1))" @onclick="() => State.MoveLayer(layer.Id, -1)">↓</button>
                                <button class="layer-delete" title="@T("Delete layer", "Ebene löschen")" disabled="@(layer.Generated || layer.Locked)" @onclick="() => RemoveLayer(layer)">×</button>
                            </div>
                        }
                    }
                    <div class="base-layer"><span>▦</span><div><strong>@T("Generated world", "Generierte Welt")</strong><small>@T("Base · always locked", "Basis · immer gesperrt")</small></div><span>🔒</span></div>
                </div>
            </section>
        </aside>
    </main>

    @if (State.Error is not null) { <div class="toast error-toast"><span>!</span><div><strong>@T("Action completed with a note", "Aktion mit Hinweis abgeschlossen")</strong><p>@ErrorText(State.Error)</p></div><button @onclick="State.ClearError">×</button></div> }
    @if (State.IsBusy) { <div class="busy-line"></div> }
</div>

@if (showOnboarding)
{
    <div class="modal-backdrop onboarding-backdrop">
        <div class="settings-modal panel onboarding-modal" role="dialog" aria-modal="true" aria-labelledby="onboarding-title">
            <div class="onboarding-hero"><img class="onboarding-logo" src="/sprite2world-logo.png" alt="Sprite2World" width="450" height="154" style="display:block;width:450px;max-width:90%;height:154px;object-fit:contain;margin:0 0 2px" /><span class="eyebrow">@T("WELCOME", "WILLKOMMEN")</span><h2 id="onboarding-title">@T("Build your first world", "Baue deine erste Welt")</h2><p>@T("Choose your language and connect your own OpenAI API key. The editor remains usable without AI.", "Wähle deine Sprache und verbinde deinen eigenen OpenAI-API-Schlüssel. Der Editor bleibt auch ohne KI nutzbar.")</p></div>
            <section><h3>@T("Language", "Sprache")</h3><div class="onboarding-language"><button class="@(Localizer.Language == "en" ? "active" : "")" @onclick='() => SetOnboardingLanguage("en")'>English</button><button class="@(Localizer.Language == "de" ? "active" : "")" @onclick='() => SetOnboardingLanguage("de")'>Deutsch</button></div></section>
            <section class="credential-section"><h3>@T("Connect OpenAI", "OpenAI verbinden")</h3><label>@T("API key", "API-Schlüssel")<input type="password" autocomplete="new-password" spellcheck="false" @bind="apiKeyInput" @bind:event="oninput" placeholder="sk-…" /></label><p class="credential-privacy"><span class="material-symbols-rounded">shield_lock</span>@T("Your key is validated directly with OpenAI. Only an encrypted token is stored in this browser; the key is never written into the app or project files.", "Dein Schlüssel wird direkt bei OpenAI geprüft. In diesem Browser wird nur ein verschlüsseltes Token gespeichert; der Schlüssel wird nie in die App oder Projektdateien geschrieben.")</p>@if (!string.IsNullOrWhiteSpace(apiKeyMessage)) { <p class="credential-result @(apiKeyHasError ? "error" : "success")">@apiKeyMessage</p> }</section>
            <div class="onboarding-actions"><button class="button" @onclick="ContinueWithoutAi" disabled="@validatingApiKey">@(Credentials.IsReady ? T("Open Sprite2World", "Sprite2World öffnen") : T("Continue without AI", "Ohne KI fortfahren"))</button><button class="button primary" @onclick="ValidateApiKey" disabled="@(validatingApiKey || string.IsNullOrWhiteSpace(apiKeyInput))">@(validatingApiKey ? T("Checking…", "Wird geprüft…") : Credentials.IsReady ? T("Test another key", "Anderen Schlüssel testen") : T("Check and continue", "Prüfen und fortfahren"))</button></div>
        </div>
    </div>
}

@if (showSettings)
{
    <div class="modal-backdrop settings-backdrop" @onclick="() => showSettings = false"><div class="settings-modal panel" role="dialog" aria-modal="true" aria-label="@T("Settings", "Einstellungen")" tabindex="-1" @onkeydown="e => CloseOnEscape(e, () => showSettings = false)" @onclick:stopPropagation="true">
        <div class="modal-heading"><div><span class="eyebrow">@T("SETTINGS", "EINSTELLUNGEN")</span><h2>Sprite2World</h2></div><button class="icon-button" aria-label="@T("Close settings", "Einstellungen schließen")" @onclick="() => showSettings = false">×</button></div>
        <section><h3>@T("Language", "Sprache")</h3><label>@T("Interface language", "Oberflächensprache")<select value="@Localizer.Language" @onchange="ChangeLanguage"><option value="en">English</option><option value="de">Deutsch</option></select></label><p class="settings-note">@T("English is the default language. Your selection is saved in this browser.", "Englisch ist die Standardsprache. Deine Auswahl wird in diesem Browser gespeichert.")</p></section>
        <section class="credential-section"><h3>OpenAI</h3><div class="credential-status"><span class="status-dot @(Credentials.IsReady ? "online" : "offline")"></span><strong>@(Credentials.IsReady ? T("AI ready", "KI bereit") : T("AI locked", "KI gesperrt"))</strong><span>@T(Credentials.Status, Credentials.Status switch { "OpenAI connected" => "OpenAI verbunden", "No API key configured" => "Kein API-Schlüssel hinterlegt", _ => Credentials.Status })</span></div><label>@T(Credentials.IsReady ? "API key securely stored · enter only to replace" : "API key", Credentials.IsReady ? "API-Schlüssel sicher gespeichert · nur zum Ersetzen eingeben" : "API-Schlüssel")<input type="password" autocomplete="new-password" spellcheck="false" @bind="apiKeyInput" @bind:event="oninput" placeholder="@(Credentials.IsReady ? T("•••••••••••• · securely stored", "•••••••••••• · sicher gespeichert") : "sk-…")" /></label><div class="credential-actions"><button class="button primary" @onclick="ValidateApiKey" disabled="@(validatingApiKey || string.IsNullOrWhiteSpace(apiKeyInput))">@(validatingApiKey ? T("Checking…", "Wird geprüft…") : T("Validate key", "Schlüssel prüfen"))</button>@if (Credentials.IsReady) { <button class="button danger" @onclick="RemoveApiKey" disabled="@validatingApiKey">@T("Remove key", "Schlüssel entfernen")</button> }</div>@if (!string.IsNullOrWhiteSpace(apiKeyMessage)) { <p class="credential-result @(apiKeyHasError ? "error" : "success")">@apiKeyMessage</p> }<p class="settings-note">@T("For security, the saved key is never shown in plaintext. The masked field confirms that it is connected.", "Aus Sicherheitsgründen wird der gespeicherte Schlüssel nie im Klartext angezeigt. Das maskierte Feld bestätigt die Verbindung.")</p><label>@T("Model", "Modell")<OpenAiModelSelect Value="@State.Model" ValueChanged="ChangeModel" CssClass="settings-model-select" Language="@Localizer.Language" /></label><label>@T("Reasoning effort", "Denkaufwand")<select @bind="State.ReasoningEffort" @bind:after="ScheduleAutoSave"><option value="low">@T("Low", "Niedrig")</option><option value="medium">@T("Medium", "Mittel")</option><option value="high">@T("High", "Hoch")</option></select></label><p class="settings-note">@T("GPT-5.6 Luna is preselected for cost-sensitive testing. Terra and Sol remain available for higher quality requirements.", "GPT-5.6 Luna ist für kostensensitive Tests vorausgewählt. Terra und Sol bleiben für höhere Qualitätsanforderungen verfügbar.")</p></section>
        <section><h3>@T("Display", "Anzeige")</h3><label class="switch-row">@T("Show grid", "Raster anzeigen")<input type="checkbox" @bind="showGrid" @bind:after="ApplyDisplaySettings" /></label><label>@T("Default zoom", "Standard-Zoom")<input type="range" min="0.5" max="2" step="0.1" @bind="zoom" @bind:after="ApplyDisplaySettings" /></label></section>
