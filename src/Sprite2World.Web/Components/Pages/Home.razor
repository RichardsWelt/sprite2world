            "Importing and validating assets…" => T("Importing and validating assets…", "Assets werden importiert und geprüft…"), "Creating original demo asset pack…" => T("Creating original demo asset pack…", "Originales Demo-Asset-Paket wird erstellt…"),
            "Demo assets loaded" => T("Demo assets loaded", "Demo-Assets geladen"), "OpenAI is classifying the asset library…" => T("OpenAI is classifying the asset library…", "OpenAI klassifiziert die Asset-Bibliothek…"),
            "AI classification complete" => T("AI classification complete", "KI-Klassifizierung abgeschlossen"), "OpenAI is designing the semantic blueprint…" => T("OpenAI is designing the semantic blueprint…", "OpenAI entwirft den semantischen Plan…"),
            "Building deterministic world…" => T("Building deterministic world…", "Deterministische Welt wird erstellt…"), "Improving semantic blueprint from feedback…" => T("Improving semantic blueprint from feedback…", "Semantischer Plan wird anhand des Feedbacks verbessert…"),
            "Running independent validation…" => T("Running independent validation…", "Unabhängige Prüfung läuft…"), "All checks passed" => T("All checks passed", "Alle Prüfungen bestanden"), "Validation found issues" => T("Validation found issues", "Die Prüfung hat Probleme gefunden"),
            "Saving project…" => T("Saving project…", "Projekt wird gespeichert…"), "Project saved" => T("Project saved", "Projekt gespeichert"), "Opening project…" => T("Opening project…", "Projekt wird geöffnet…"),
            "New project" => T("New project", "Neues Projekt"), "Project closed" or "Projekt geschlossen" => T("Project closed", "Projekt geschlossen"), "Deleting project…" => T("Deleting project…", "Projekt wird gelöscht…"),
            "Project deleted" => T("Project deleted", "Projekt gelöscht"), "Operation failed" => T("Operation failed", "Aktion fehlgeschlagen"), _ => status
        };
        if (exact != status) return exact;
        if (status.StartsWith("Imported ", StringComparison.Ordinal)) return Localizer.IsGerman ? status.Replace("Imported ", "Importiert ").Replace(" of ", " von ").Replace(" files", " Dateien").Replace(" assets", " Assets") : status;
        if (status.StartsWith("Removed ", StringComparison.Ordinal)) return Localizer.IsGerman ? status.Replace("Removed ", "Entfernt ").Replace(" assets", " Assets") : status;
        if (status.StartsWith("World v", StringComparison.Ordinal)) return Localizer.IsGerman ? status.Replace(" generated · seed ", " generiert · Seed ") : status;
        if (status.StartsWith("Improved world ", StringComparison.Ordinal)) return Localizer.IsGerman ? status.Replace("Improved world ", "Verbesserte Welt ").Replace(" ready", " bereit") : status;
        if (status.StartsWith("Opened ", StringComparison.Ordinal)) return Localizer.IsGerman ? status.Replace("Opened ", "Geöffnet: ") : status;
        if (status.StartsWith("Restored v", StringComparison.Ordinal)) return Localizer.IsGerman ? status.Replace("Restored ", "Wiederhergestellt: ") : status;
        if (status.StartsWith("Category assigned: ", StringComparison.Ordinal)) return T(status, $"Rubrik zugewiesen: {LocalizedCategory(status[19..])}");
        if (status.StartsWith("Layer added: ", StringComparison.Ordinal)) return T(status, $"Ebene hinzugefügt: {LocalizedLayerText(status[13..])}");
        if (status.StartsWith("Layer removed: ", StringComparison.Ordinal)) return T(status, $"Ebene entfernt: {LocalizedLayerText(status[15..])}");
        if (status.StartsWith("Drawing on ", StringComparison.Ordinal) || status.StartsWith("Zeichnen auf ", StringComparison.Ordinal)) { var layer = status.Replace("Zeichnen auf ", "").Replace("Drawing on ", ""); return T($"Drawing on {LocalizedLayerText(layer)}", $"Zeichnen auf {LocalizedLayerText(layer)}"); }
        if (status.StartsWith("Erased on ", StringComparison.Ordinal) || status.StartsWith("Radiert auf ", StringComparison.Ordinal)) { var layer = status.Replace("Radiert auf ", "").Replace("Erased on ", ""); return T($"Erased on {LocalizedLayerText(layer)}", $"Radiert auf {LocalizedLayerText(layer)}"); }
        return status;
    }
    private string LocalizedLayerText(string value) => value switch
    {
        "Floor & Walls" or "Boden & Wände" => T("Floor & Walls", "Boden & Wände"),
        "Decorations" or "Dekorationen" => T("Decorations", "Dekorationen"),
        _ when value.StartsWith("Layer ", StringComparison.Ordinal) && Localizer.IsGerman => value.Replace("Layer ", "Ebene "),
        _ when value.StartsWith("Ebene ", StringComparison.Ordinal) && !Localizer.IsGerman => value.Replace("Ebene ", "Layer "),
        _ => value
    };
    private string LocalizedClassificationSource(string value) => value switch
    {
        "Unclassified" => T("Unclassified", "Nicht klassifiziert"), "Folder hint" => T("Folder hint", "Ordnerhinweis"),
        "Demo manifest" => T("Demo manifest", "Demo-Manifest"), "OpenAI vision" => T("OpenAI vision", "OpenAI-Bilderkennung"),
        "Manual" => T("Manual", "Manuell"), _ => value
    };
    private string ErrorText(string error)
    {
        if (error == "The operation failed. Check docker compose logs for details.") return T(error, "Die Aktion ist fehlgeschlagen. Details stehen in den Docker-Compose-Logs.");
        if (error == "The saved project no longer exists.") return T(error, "Das gespeicherte Projekt existiert nicht mehr.");
        if (error == "OpenAI returned overlapping sprite pixels.") return T(error, "OpenAI hat sich überschneidende Sprite-Pixel zurückgegeben.");
        if (error == "OpenAI returned an invalid sprite run.") return T(error, "OpenAI hat eine ungültige Pixelzeile zurückgegeben.");
        if (error.StartsWith("AI fallback: ", StringComparison.Ordinal) && Localizer.IsGerman) return error.Replace("AI fallback: ", "KI-Fallback: ");
        return error;
    }
    private static string Percent(double? value) => value is null ? "—" : $"{value:P0}";
    private static string Point(GridPoint? value) => value is null ? "—" : $"({value.Value.X}, {value.Value.Y})";
    private string RoleLabel(AssetRole role) => Localizer.Role(role);
    private string LayerPurposeLabel(WorldLayer layer) => layer.Purpose switch
    {
        LayerPurpose.Terrain => T($"Layer {layer.Order} · Floor/Walls", $"Ebene {layer.Order} · Boden/Wände"),
        LayerPurpose.Decoration => T($"Layer {layer.Order} · Decoration", $"Ebene {layer.Order} · Dekoration"),
        _ => T($"Layer {layer.Order} · User", $"Ebene {layer.Order} · Benutzer")
    };
    private void ScheduleAutoSave()
    {
        autoSaveDebounce?.Cancel(); autoSaveDebounce?.Dispose();
        autoSaveDebounce = new CancellationTokenSource();
        _ = AutoSaveAfterDelayAsync(autoSaveDebounce.Token);
    }
    private async Task AutoSaveAfterDelayAsync(CancellationToken cancellationToken)
    {
        try { await Task.Delay(700, cancellationToken); await State.AutoSaveAsync(cancellationToken); await InvokeAsync(() => SaveWorldPreviewAsync(cancellationToken)); }
        catch (OperationCanceledException) { }
        catch (Exception ex) { Logger.LogWarning(ex, "Automatic project save failed"); }
    }
    private async Task SaveWorldPreviewAsync(CancellationToken cancellationToken = default)
    {
        if (State.World is null || libraryStudioOpen || cancellationToken.IsCancellationRequested) return;
        try
        {
            var base64 = await JS.InvokeAsync<string?>("sprite2world.previewBase64", cancellationToken, "worldCanvas", 1600);
            if (!string.IsNullOrWhiteSpace(base64)) await State.SaveWorldPreviewAsync(base64, cancellationToken);
        }
        catch (JSException ex) { Logger.LogDebug(ex, "World preview is not ready yet"); }
    }
    private void ScheduleSpriteAutoSave()
    {
        spriteAutoSaveDebounce?.Cancel(); spriteAutoSaveDebounce?.Dispose();
        spriteAutoSaveDebounce = new CancellationTokenSource();
        _ = AutoSaveSpriteAfterDelayAsync(spriteAutoSaveDebounce.Token);
    }
    private async Task AutoSaveSpriteAfterDelayAsync(CancellationToken cancellationToken)
    {
        try { await Task.Delay(650, cancellationToken); await InvokeAsync(() => SaveSpriteNowAsync(cancellationToken)); }
        catch (OperationCanceledException) { }
        catch (Exception ex) { Logger.LogWarning(ex, "Automatic sprite save failed"); }
    }
    private async Task SaveSpriteNowAsync(CancellationToken cancellationToken = default)
    {
        var asset = StudioAsset;
        if (!spriteDirty || spriteAutosaving || asset is null || activeMaterialChannel == MaterialChannel.Lit || cancellationToken.IsCancellationRequested) return;
        var base64 = await JS.InvokeAsync<string?>("spriteStudio.exportBase64", cancellationToken, "spriteEditorCanvas");
        if (string.IsNullOrWhiteSpace(base64)) return;
        spriteAutosaving = true; await InvokeAsync(StateHasChanged);
        try
        {
            if (activeMaterialChannel == MaterialChannel.Base) await State.SaveSpriteImageAsync(asset, base64);
            else await State.SaveMaterialMapAsync(asset, activeMaterialChannel, base64, false);
            spriteDirty = false;
            await JS.InvokeVoidAsync("spriteStudio.markSaved", cancellationToken, "spriteEditorCanvas");
        }
        finally { spriteAutosaving = false; await InvokeAsync(StateHasChanged); }
    }
    public ValueTask DisposeAsync() { State.Changed -= StateChanged; Localizer.Changed -= LanguageChanged; autoSaveDebounce?.Cancel(); autoSaveDebounce?.Dispose(); spriteAutoSaveDebounce?.Cancel(); spriteAutoSaveDebounce?.Dispose(); dotNetReference?.Dispose(); return ValueTask.CompletedTask; }
