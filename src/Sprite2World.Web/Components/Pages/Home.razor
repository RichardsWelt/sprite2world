    private string NewSpriteFolderPath
    {
        get => LibraryFolderPath(newSpriteFolderTheme, newSpriteFolderSubfolder);
        set
        {
            var parts = (value ?? "").Split('/', 2, StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
            newSpriteFolderTheme = NormalizeLibraryThemeName(parts.FirstOrDefault());
            newSpriteFolderSubfolder = NormalizeLibraryFolderName(parts.Length > 1 ? parts[1] : null, "Sprites");
        }
