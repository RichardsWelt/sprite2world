    private async Task ImportFiles(InputFileChangeEventArgs e)
    {
        var browserFiles = e.GetMultipleFiles(MaxUploadFiles);
        var previousIds = State.Assets.Select(asset => asset.Id).ToHashSet(StringComparer.Ordinal);
        var processed = 0;
        foreach (var batch in browserFiles.Chunk(ImportBatchSize))
        {
            var files = new List<(string, byte[])>(batch.Length);
            foreach (var file in batch)
            {
                await using var stream = file.OpenReadStream(MaxUploadFileBytes);
                using var memory = new MemoryStream();
                await stream.CopyToAsync(memory);
                var data = memory.ToArray();
                if (Path.GetExtension(file.Name).Equals(".png", StringComparison.OrdinalIgnoreCase))
                {
                    var resized = await JS.InvokeAsync<string>("spriteStudio.resizeBase64", Convert.ToBase64String(data), NewSpritePixelWidth, NewSpritePixelHeight);
                    data = Convert.FromBase64String(resized);
                }
                files.Add((file.Name, data));
            }
            await State.ImportAsync(files, processed, browserFiles.Count);
            processed += batch.Length;
        }
        visibleAssetLimit = AssetPageSize;
        studioAssetId = State.Assets.FirstOrDefault(asset => !previousIds.Contains(asset.Id))?.Id ?? studioAssetId ?? State.Assets.FirstOrDefault()?.Id;
        libraryAddOpen = false; showSpriteSetupDialog = false; activeMaterialChannel = MaterialChannel.Base;
        pendingSpriteStudioRender = true;
        pendingCanvasRender = true;
    }
