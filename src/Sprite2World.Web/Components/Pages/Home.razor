    private async Task CreateAiSizedCopy()
    {
        var asset = StudioAsset; if (asset is null) return;
        var source = await JS.InvokeAsync<string?>("spriteStudio.exportBase64", "spriteEditorCanvas"); if (string.IsNullOrWhiteSpace(source)) return;
        var resized = await JS.InvokeAsync<string>("spriteStudio.resizeBase64", source, SpriteTilePixels, SpriteTilePixels);
        var created = await State.CreateSpriteAsync($"{Path.GetFileNameWithoutExtension(asset.FileName)}-1x1", SpriteTilePixels, SpriteTilePixels, resized);
        if (created is not null) { studioAssetId = created.Id; activeMaterialChannel = MaterialChannel.Base; showAiSpriteDialog = false; pendingSpriteStudioRender = true; }
    }
    private async Task GenerateAiSprite()
    {
        var asset = StudioAsset;
        if (asset is null || !SpriteAiSizeSupported || string.IsNullOrWhiteSpace(aiSpritePrompt)) return;
        var options = new SpriteGenerationOptions(aiSpriteView, aiSpriteFraming, aiSpriteOutline, aiSpriteLighting, aiSpritePaletteHint, State.ReasoningEffort);
        aiSpriteCancellation?.Dispose(); aiSpriteCancellation = new CancellationTokenSource();
        aiSpriteCandidate = null; aiSuccessPulse = false; aiRequestActive = true;
        await SetAiProgress(T("Preparing prompt and canvas rules", "Prompt und Canvas-Regeln werden vorbereitet"));
        await SetAiProgress(T("Sending request to OpenAI", "Anfrage wird an OpenAI gesendet"));
        await Task.Delay(32);
        var generationTask = State.GenerateSpriteAsync(aiSpritePrompt, asset.Width, asset.Height, options, aiSpriteCancellation.Token);
        await SetAiProgress(T("OpenAI is planning and drawing the pixels", "OpenAI plant und zeichnet die Pixel"));
        var generated = await generationTask;
        aiRequestActive = false;
        if (generated is null || StudioAsset?.Id != asset.Id)
        {
            var failed = !string.IsNullOrWhiteSpace(State.Error);
            await SetAiProgress(failed ? T("Request failed", "Anfrage fehlgeschlagen") : T("Generation cancelled", "Generierung abgebrochen"), false, failed, false, failed ? ErrorText(State.Error!) : "");
            return;
        }
        aiSpriteCandidate = generated;
        await SetAiProgress(T("Response received — pixels and quality checks passed", "Antwort empfangen – Pixel und Qualitätsprüfung abgeschlossen"));
        await JS.InvokeVoidAsync("spriteStudio.renderGeneratedPreview", "aiSpritePreview", asset.Width, asset.Height, generated.Pixels);
        await SetAiProgress(T("Preview ready", "Vorschau bereit"), false, false, true);
    }
    private async Task AcceptAiSprite()
    {
        var asset = StudioAsset; var generated = aiSpriteCandidate;
        if (asset is null || generated is null) return;
        aiSpriteDrawing = true; aiSuccessPulse = false;
        await SetAiProgress(T("Applying pixels to the sprite", "Pixel werden auf den Sprite übertragen"));
        try
        {
            await JS.InvokeVoidAsync("spriteStudio.applyGeneratedPixels", "spriteEditorCanvas", generated.Pixels);
            await SetAiProgress(T("Saving AI result", "KI-Ergebnis wird gespeichert"));
            await State.SaveSpriteAiMetadataAsync(asset, generated);
            await SetAiProgress(T("Sprite applied and saved", "Sprite übernommen und gespeichert"), false, false, true);
            await Task.Delay(1100);
            showAiSpriteDialog = false; aiSpriteCandidate = null;
        }
        catch (JSException ex) { Logger.LogWarning(ex, "AI sprite animation failed"); await SetAiProgress(T("Sprite could not be applied", "Sprite konnte nicht übernommen werden"), false, true); }
        finally { aiSpriteDrawing = false; await InvokeAsync(StateHasChanged); }
    }
