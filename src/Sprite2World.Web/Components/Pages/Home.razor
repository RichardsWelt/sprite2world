            <div class="modal-heading"><div><span class="eyebrow">@T("NEW WORLD", "NEUE WELT")</span><h2 id="world-setup-title">@T("Choose the world before generating", "Welt vor dem Generieren festlegen")</h2></div><button class="icon-button" aria-label="@T("Close", "Schließen")" @onclick="() => showWorldSetupDialog = false">×</button></div>
            <section><label>@T("Name", "Name")<input @bind="newProjectName" @bind:event="oninput" maxlength="80" /></label><div class="world-kind-picker setup-picker" role="group" aria-label="@T("World type", "Welttyp")">@foreach (var kind in new[] { "Dungeon", "Interior", "Overworld" }) { <button aria-pressed="@(newWorldEnvironment == kind ? "true" : "false")" class="@(newWorldEnvironment == kind ? "active" : "")" @onclick="() => SetNewWorldEnvironment(kind)"><strong>@kind</strong><small>@WorldKindDescription(kind)</small></button> }</div><label>@T("Initial idea", "Erste Idee")<textarea @bind="newWorldPrompt" @bind:event="oninput" maxlength="800"></textarea></label><p class="settings-note">@T("Nothing is generated until you confirm. You can refine this description again in the world editor.", "Vor der Bestätigung wird nichts generiert. Du kannst die Beschreibung anschließend im Welteditor weiter verfeinern.")</p></section>
