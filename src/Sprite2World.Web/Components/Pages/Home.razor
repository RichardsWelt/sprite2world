    protected override Task OnInitializedAsync() { State.Changed += StateChanged; Localizer.Changed += LanguageChanged; return Task.CompletedTask; }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetReference = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("sprite2world.init", "worldCanvas", dotNetReference);
            var savedLanguage = await JS.InvokeAsync<string?>("sprite2world.getPreference", "language");
            if (savedLanguage is "en" or "de")
            {
                var promptIsDefault = State.Prompt is DefaultPromptEnglish or DefaultPromptGerman;
                var feedbackIsDefault = State.Feedback is DefaultFeedbackEnglish or DefaultFeedbackGerman;
                Localizer.SetLanguage(savedLanguage);
                if (promptIsDefault) State.Prompt = T(DefaultPromptEnglish, DefaultPromptGerman);
                if (feedbackIsDefault) State.Feedback = T(DefaultFeedbackEnglish, DefaultFeedbackGerman);
                newProjectName = T("New Project", "Neues Projekt");
                await JS.InvokeVoidAsync("sprite2world.setPreference", "language", savedLanguage);
            }
            var protectedCredential = await JS.InvokeAsync<string?>("sprite2world.getPreference", "openAiCredential");
            var restoredCredential = await Credentials.RestoreAsync(protectedCredential);
            if (!restoredCredential && !string.IsNullOrWhiteSpace(protectedCredential))
                await JS.InvokeVoidAsync("sprite2world.setPreference", "openAiCredential", "");
            if (!restoredCredential && Credentials.HasConfiguredServerKey)
            {
                var configuredKeyResult = await Credentials.ValidateConfiguredServerKeyAsync();
                restoredCredential = configuredKeyResult.Success;
                if (configuredKeyResult.Success && configuredKeyResult.ProtectedToken is not null)
                    await JS.InvokeVoidAsync("sprite2world.setPreference", "openAiCredential", configuredKeyResult.ProtectedToken);
            }
            var onboardingComplete = await JS.InvokeAsync<string?>("sprite2world.getPreference", "onboardingComplete");
            showOnboarding = onboardingComplete != "true";
            await LoadSpriteColorPreferences();
            var activeProjectId = await JS.InvokeAsync<string?>("sprite2world.getPreference", "activeProjectId");
