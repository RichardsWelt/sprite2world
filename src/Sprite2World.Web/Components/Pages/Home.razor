        return normalized[..Math.Min(normalized.Length, 40)];
    }
    private static string NormalizeLibraryThemeName(string? value)
    {
        var normalized = NormalizeLibraryFolderName(value, "General");
        return normalized.Equals("Allgemein", StringComparison.OrdinalIgnoreCase) ? "General" : normalized;
