    private List<string> PaletteFor(MaterialChannel channel)
    {
        var key = PaletteChannel(channel);
        if (spritePalettes.TryGetValue(key, out var palette)) return palette;
        var defaults = key == MaterialChannel.Normal ? NormalPalette : key is MaterialChannel.Metallic or MaterialChannel.Roughness ? ScalarPalette : SpritePalette;
        palette = defaults.Distinct(StringComparer.OrdinalIgnoreCase).ToList(); spritePalettes[key] = palette; return palette;
