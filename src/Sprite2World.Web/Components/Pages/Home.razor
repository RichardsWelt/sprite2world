            <div class="modal-heading"><div><span class="eyebrow">@T("PROJECTS", "PROJEKTE")</span><h2>@T("Project management", "Projektverwaltung")</h2></div><button class="icon-button" aria-label="@T("Close project management", "Projektverwaltung schließen")" @onclick="() => showProjects = false">×</button></div>
            <div class="project-actions">
                <div class="project-create"><input aria-label="@T("New project name", "Name des neuen Projekts")" placeholder="@T("Project name", "Projektname")" @bind="newProjectName" @bind:event="oninput" /><button class="button primary" @onclick="NewProject">＋ @T("Create", "Erstellen")</button></div>
