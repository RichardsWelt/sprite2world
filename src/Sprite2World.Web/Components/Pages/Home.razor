    private bool CanMoveLayer(WorldLayer layer, int delta)
    {
        if (State.World is null || layer.Locked) return false;
        var ordered = State.World.Layers.OrderBy(item => item.Order).ToList();
        var index = ordered.FindIndex(item => item.Id == layer.Id); var target = index + delta;
        return index >= 0 && target >= 0 && target < ordered.Count && !ordered[target].Locked;
    }
