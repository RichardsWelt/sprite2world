            <div class="autosave-note"><span class="status-dot online"></span>@T("Changes are saved automatically.", "Änderungen werden automatisch gespeichert.")</div>
            <div class="current-project"><span class="status-dot @(State.HasOpenProject ? "online" : "offline")"></span><div><small>@T("CURRENT", "AKTUELL")</small><strong>@LocalizedProjectName(State.ProjectName)</strong></div></div>
